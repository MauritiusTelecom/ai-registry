{
  "name": "airegistry-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "AI Registry reference implementation - core, SDK, UI kit, and default portal.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "prepare": "node scripts/install-git-hooks.mjs",
    "dev": "turbo run dev --filter=@airegistry/portal",
    "start": "pnpm --filter @airegistry/portal start",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "prisma:generate": "pnpm --filter @airegistry/core prisma:generate",
    "prisma:validate": "pnpm --filter @airegistry/core prisma:validate",
    "prisma:format": "pnpm --filter @airegistry/core prisma:format",
    "prisma:migrate": "pnpm --filter @airegistry/core prisma:migrate",
    "db:push": "pnpm --filter @airegistry/core db:push",
    "db:seed": "pnpm --filter @airegistry/core db:seed",
    "db:reset": "pnpm --filter @airegistry/core db:reset",
    "db:bootstrap": "pnpm --filter @airegistry/core db:bootstrap",
    "deploy:db": "pnpm --filter @airegistry/core deploy:db",
    "config:validate": "pnpm --filter @airegistry/portal config:validate",
    "check:env-secrets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-no-env-secrets.ps1",
    "install:hooks": "node scripts/install-git-hooks.mjs",
    "test:emails": "pnpm --filter @airegistry/portal test:emails",
    "test:smtp": "pnpm --filter @airegistry/portal test:smtp",
    "smoke": "pnpm --filter @airegistry/portal smoke",
    "deploy": "bash deploy/deploy.sh",
    "deploy:dry": "DRY_RUN=1 bash deploy/deploy.sh",
    "deploy:db:remote": "bash deploy/deploy-db.sh",
    "deploy:v2": "bash scripts/deploy-v2.sh",
    "backup:prod": "bash scripts/backup-prod.sh"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5"
  }
}
