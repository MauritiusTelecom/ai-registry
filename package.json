{
  "name": "airegistry",
  "version": "0.1.0",
  "private": true,
  "description": "Mauritius AI Registry — Next.js public portal and Prisma schema",
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:format": "prisma format",
    "prisma:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx src/prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && npm run db:seed",
    "deploy:db": "prisma generate && prisma db push --skip-generate",
    "db:bootstrap": "prisma generate && prisma db push --skip-generate && tsx src/prisma/seed.ts",
    "deploy:v2": "bash scripts/deploy.sh v2",
    "deploy:legacy": "bash scripts/deploy.sh legacy",
    "config:validate": "tsx scripts/validate-config.ts",
    "test:emails": "tsx scripts/test-emails.ts",
    "test:smtp": "tsx scripts/test-smtp.ts",
    "smoke": "tsx scripts/smoke-public.ts",
    "deploy": "bash deploy/deploy.sh",
    "deploy:dry": "DRY_RUN=1 bash deploy/deploy.sh",
    "deploy:db:remote": "bash deploy/deploy-db.sh"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "tsx src/prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "nodemailer": "^6.10.1",
    "next": "^16.0.1",
    "prisma": "^6.19.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.17",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "dotenv": "^16.4.5",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.1",
    "typescript": "^5"
  }
}
