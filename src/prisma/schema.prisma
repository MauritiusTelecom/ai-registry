// airegistry — Prisma schema (PostgreSQL `registry`)
// Aligned with the normative data model in `airegistry-specs/data-model.md` and
// the reference implementation in `ai-registry/src/prisma/schema.prisma`.
//
// Convention: every controlled vocabulary is a small reference table
// (id / code / name / description / active / sortOrder). No SQL enums.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["registry"]
}

// ─── Reference tables (replace former enums) ────────────

model UserRoleType {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  roleAssignments UserRoleAssignment[]

  @@schema("registry")
}

