// ─── User ───────────────────────────────────────────────

model User {
  id                      String    @id @default(uuid()) @db.Uuid
  email                   String    @unique
  passwordHash            String?
  name                    String
  organisationName        String?
  roleId                  String
  statusId                String
  providerId              String?
  emailVerified           Boolean   @default(false)
  verificationToken       String?
  verificationTokenExpiry DateTime?
  resetToken              String?
  resetTokenExpiry        DateTime?
  onboardingComplete      Boolean   @default(true)
  /** Bumped on password reset to invalidate existing session cookies. */
  sessionEpoch            Int       @default(0)
  image                   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  role     UserRoleType   @relation(fields: [roleId], references: [id], onDelete: Restrict)
  status   UserStatusType @relation(fields: [statusId], references: [id], onDelete: Restrict)
  provider Provider?      @relation(fields: [providerId], references: [id])

  accounts                 Account[]
  auditLogs                AuditLog[]
  roleAssignments          UserRoleAssignment[]
  reviewedReviews          Review[]                        @relation("ReviewerOfReview")
  evidenceSubmissions      SovereigntyEvidence[]           @relation("EvidenceSubmittedBy")
  resourceBasisSubmissions ResourceSovereigntyBasis[]      @relation("BasisSubmittedBy")
  authorisationDecisions   OfficialResourceAuthorisation[] @relation("AuthorisationDecidedBy")
  trustSignalDecisions     TrustSignal[]                   @relation("TrustSignalDecidedBy")
  complaintsAssigned       Complaint[]                     @relation("ComplaintAssignedTo")
  enforcementActions       EnforcementAction[]             @relation("EnforcementPerformedBy")
  contacts                 Contact[]
  notificationReads        NotificationRead[]
  threadsOpened            ReviewThread[]            @relation("ReviewThreadOpenedBy")
  threadsResolved          ReviewThread[]            @relation("ReviewThreadResolvedBy")
  threadMessages           ReviewThreadMessage[]
  threadAttachmentsUploaded ReviewThreadAttachment[]

  @@index([providerId])
  @@index([roleId])
  @@index([statusId])
  @@schema("registry")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@schema("registry")
}

model UserRoleAssignment {
  id                  String   @id @default(uuid())
  userId              String   @db.Uuid
  roleId              String
  scopeJurisdictionId String?
  scopeProviderId     String?
  scopeSectorId       String?
  assignedAt          DateTime @default(now())
  assignedById        String?  @db.Uuid

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role UserRoleType @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, roleId, scopeJurisdictionId, scopeProviderId, scopeSectorId])
  @@index([userId])
  @@index([roleId])
  @@schema("registry")
}

// ─── Jurisdiction ───────────────────────────────────────

model Jurisdiction {
  id                   String   @id @default(uuid())
  code                 String   @unique
  name                 String
  typeId               String
  parentJurisdictionId String?
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  type   JurisdictionType @relation(fields: [typeId], references: [id], onDelete: Restrict)
  parent Jurisdiction?    @relation("JurisdictionHierarchy", fields: [parentJurisdictionId], references: [id])

  children            Jurisdiction[]      @relation("JurisdictionHierarchy")
  providers           Provider[]
  resources           Resource[]
  officialAuthorities OfficialAuthority[]
  federatedRegistries FederatedRegistry[]

  @@index([active])
  @@index([typeId])
  @@schema("registry")
}

// ─── Provider ───────────────────────────────────────────

model Provider {
  id                 String   @id @default(uuid())
  slug               String   @unique
  displayName        String
  legalName          String?
  typeId             String
  homeJurisdictionId String
  websiteUrl         String?
  documentationUrl   String?
  contactEmail       String
  legalContactEmail  String?
  registrationNumber String?
  description        String?
  statusId           String
  published          Boolean  @default(true)
  adminSuspended     Boolean  @default(false)
  srcId              String
  // Provider notification preferences (modules/provider/settings/product.md §
  // Notifications card). Free-form so the operator can use any chat handle
  // (Slack, Teams, Matrix). Webhook is optional outbound for incident events.
  incidentChannel    String?
  oncallEmail        String?
  webhookUrl         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  type             ProviderTypeRef      @relation(fields: [typeId], references: [id], onDelete: Restrict)
  homeJurisdiction Jurisdiction         @relation(fields: [homeJurisdictionId], references: [id], onDelete: Restrict)
  status           ProviderStatusType   @relation(fields: [statusId], references: [id], onDelete: Restrict)
  src              SubmissionSourceType @relation(fields: [srcId], references: [id], onDelete: Restrict)

  resources          Resource[]
  users              User[]
  trustSignals       TrustSignal[]
  reviews            Review[]
  complaints         Complaint[]
  enforcementActions EnforcementAction[]

  @@index([homeJurisdictionId])
  @@index([statusId])
  @@index([typeId])
  @@index([published])
  @@schema("registry")
}

