// airegistry — Prisma schema (PostgreSQL `registry`)
// Aligned with the normative data model in `airegistry-specs/data-model.md` and
// the reference implementation in `ai-registry/src/prisma/schema.prisma`.
//
// Convention: every controlled vocabulary is a small reference table
// (id / code / name / description / active / sortOrder). No SQL enums.

generator client {
  provider      = "prisma-client-js"
  // From packages/core/prisma/, ../src/generated/prisma → packages/core/src/generated/prisma
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // `registry` holds the core domain: providers, resources, reviews, audit,
  // users, etc. `public_cms` holds operator-editable public-site content
  // (FAQ, "how it works" steps, listing criteria, promo banner) so the
  // marketing / discovery surface can be customised from /admin/site/* without
  // touching code or env. Branding (registry name, logo, eyebrow text) stays
  // in `registry.SiteBranding` because it's also consumed by role-portal
  // chrome, not just the public site.
  schemas  = ["registry", "public_cms"]
}

