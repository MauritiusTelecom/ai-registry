{
  "id": "mu-brn-check",
  "name": "Mauritius BRN Check",
  "version": "0.2.0",
  "license": "Apache-2.0",
  "maintainer": "Mauritius Telecom <airegistry@telecom.mu>",
  "coreRange": "^0.2.0",
  "description": "Declares the Mauritius Business Registration Number verification requirement for every MU-jurisdiction provider. Verification is performed manually by an admin against the uploaded company-registration certificate; the BRN format is validated locally via the REST handler.",
  "homepage": "https://www.airegistry.mu/",
  "verificationRequirements": [
    {
      "code": "brn",
      "label": "Business Registration Number (Mauritius)",
      "appliesWhen": {
        "providerJurisdiction": ["MU"]
      },
      "documentTypeHint": "company_registration"
    }
  ],
  "rest": [
    {
      "path": "/validate",
      "methods": ["POST", "GET"],
      "handler": "@airegistry/extension-mauritius-brn-check/rest/validate"
    }
  ],
  "permissions": [
    {
      "code": "rest:mount",
      "description": "Mount REST routes under /api/ext/mu-brn-check/"
    }
  ]
}
