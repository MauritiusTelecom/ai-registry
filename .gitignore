.env.production.local
.env.prod
.env.*.local
packages/core/.env

# Build artefacts
.next/
out/
dist/
.turbo/
*.tsbuildinfo

# Prisma generated client (output target lives in packages/core)
packages/core/src/generated/

# Logos uploaded via /admin/branding land here at runtime. Per-deployment
# state, not source.
apps/portal/public/branding/

# Review-thread attachments live on the server filesystem under
# THREAD_ATTACHMENT_ROOT (default ./storage). Per-deployment runtime state,
# never source.
/storage/

# Local-only deploy machine config (host, user, paths). Real values live here.
deploy/deploy.config.sh
# Never commit anything dropped into deploy/secrets/. It is consumed by
# deploy.sh and rsync'd to the server, but the contents are sensitive.
deploy/secrets/
# Release artefacts produced by `pnpm deploy:build`.
deploy/build/
deploy/release-*.tar.gz

# Internal-only docs (CEO notes, drafts, presentations). Keep out of public repo.
docs/missing-features-ceo.md
docs/missing-features-ceo.html
