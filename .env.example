# ─── Database ─────────────────────────────────────────────
# PostgreSQL DSN. The database must expose a schema named `registry`
# (see src/prisma/schema.prisma `schemas = ["registry"]`).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/airegistry?schema=registry"

# ─── DB seed (optional bootstrap admin) ───────────────────
# If SEED_ADMIN_PASSWORD is set when you run `npm run db:seed`, the seed
# creates or updates an operator admin: active, email verified, role admin.
# Do not commit a real password; set it only in local .env or CI secrets.
# SEED_ADMIN_EMAIL="admin@registry.com"
# SEED_ADMIN_NAME="admin@registry.com"
# SEED_ADMIN_PASSWORD=""

# Optional: exemplar provider portal login (role provider, linked to seeded Provider).
# SEED_PROVIDER_EMAIL="provider@registry.com"
# SEED_PROVIDER_USER_NAME="Exemplar Provider operator"
# SEED_PROVIDER_PASSWORD=""

# ─── Deployment configuration (no jurisdiction hardcoded in app) ──
# These keys are read by src/lib/config.ts at boot. Every key in this
# block is REQUIRED — boot will fail if any is missing or invalid.

# Display name shown across the public portal and footer.
REGISTRY_NAME="Mauritius AI Registry"

# Hostname of the public portal (no scheme, no trailing slash).
PORTAL_DOMAIN="airegistry.mu"

# Base URL of the REST API. AIR-SPEC normative form is `/api/v1`;
# the reference app currently mounts under `/api`. Either is accepted.
API_BASE_URL="https://airegistry.mu/api/v1"

# ISO or local jurisdiction code (e.g. `MU`, `EU`, `IN`).
JURISDICTION="MU"

# AIR-ID namespace authority. AIR-IDs take the form
# air://{IDENTITY_DOMAIN}/{resource_type}/{provider_slug}/{resource_slug}
IDENTITY_DOMAIN="air.mu"

# Display name of the operator running this deployment.
OPERATOR_NAME="Mauritius Telecom"

# Comma-separated BCP-47 language codes the deployment serves.
SUPPORTED_LANGUAGES="en,fr,mfe"

# Default language; MUST be one of SUPPORTED_LANGUAGES.
DEFAULT_LANGUAGE="en"

# Comma-separated resource type codes the deployment accepts.
# AIR-SPEC §7 enumerates: model, agent, tool, skill.
RESOURCE_TYPES="model,agent,tool,skill"

# ─── Authentication (Phase 2) ─────────────────────────────
# HMAC signing secret for session cookies and email tokens. REQUIRED.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET="replace-with-32-byte-base64url-secret"

# Cookie name for the session (override only if multiple registries
# share a parent domain).
SESSION_COOKIE_NAME="airegistry_session"

# Session lifetime in seconds (default: 7 days).
SESSION_TTL_SECONDS="604800"

# ─── Email (optional — Phase 2 dev fallback logs links to console) ─
# Sender address surfaced in transactional emails.
MAIL_FROM="no-reply@airegistry.mu"

# SMTP transport. If any of SMTP_HOST/SMTP_PORT is unset, the email
# helper falls back to console-logging the message body — useful for
# local dev without a mail provider.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""

# Optional: first paragraph(s) of the auto-reply email after someone uses the
# public contact form at /contact. If unset, a sensible default is built from
# REGISTRY_NAME and OPERATOR_NAME (see src/lib/config.ts).
# CONTACT_FORM_REPLY_MESSAGE="We have received your enquiry and will respond within two working days."

# When true, POST /api/public/contact includes `devMessage` (raw error text) on 503 responses.
# Useful when running `next start` (NODE_ENV=production) locally. Do not enable in public production.
# CONTACT_API_VERBOSE_ERRORS=true

# ─── OAuth/OIDC (optional — placeholder for Phase 2 follow-up) ────
# When set, the registry exposes an /api/auth/oidc/<provider> handler
# that initiates the standard authorization-code flow. Leaving these
# blank disables OIDC and only password auth is offered.
# OIDC_GOOGLE_ISSUER="https://accounts.google.com"
# OIDC_GOOGLE_CLIENT_ID=""
# OIDC_GOOGLE_CLIENT_SECRET=""

# ─── Optional / runtime knobs ─────────────────────────────
# Override the dev port (defaults to 3002 in package.json scripts).
# PORT=3002

# Set to `production` in deployments to disable the design tweaks panel.
# NODE_ENV=development
