# =============================================================================
# .env.production.example
# -----------------------------------------------------------------------------
# Copy this file to deploy/secrets/.env.production and fill in the REAL values.
# The deploy pipeline (deploy/deploy.sh) uploads this file to the server, and
# PM2 loads it at process start. NEVER commit the filled-in file.
#
# Generating a real AUTH_SECRET:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
#
# Rotating values: any change to this file requires `npm run deploy` to push it
# to the server and reload PM2.
# =============================================================================

NODE_ENV=production
PORT=3002

# ─── Database ───────────────────────────────────────────────────────────────
# Production Postgres DSN. Schema MUST be `registry`.
# Prefer a managed Postgres or a hardened local instance with TLS.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=registry

# ─── App identity ───────────────────────────────────────────────────────────
REGISTRY_NAME="Mauritius AI Registry"
PORTAL_DOMAIN="airegistry.mu"
API_BASE_URL="https://www.airegistry.mu/api/v1"
JURISDICTION="MU"
IDENTITY_DOMAIN="air.mu"
OPERATOR_NAME="Mauritius Telecom"
SUPPORTED_LANGUAGES="en,fr,mfe"
# Portal UI default locale (en/fr). FR/fr normalized. Restart portal after change.
DEFAULT_LANGUAGE="en"
RESOURCE_TYPES="model,agent,tool,skill"

# ─── Authentication ─────────────────────────────────────────────────────────
# 32-byte base64url. Generate with the command at the top of this file.
# Rotating this invalidates all sessions; plan a maintenance window.
AUTH_SECRET="replace-with-32-byte-base64url-secret"
SESSION_COOKIE_NAME="airegistry_session"
SESSION_TTL_SECONDS="604800"
SESSION_TTL_ADMIN_SECONDS="28800"
TRUST_FORWARDED_HEADERS="true"
PLUGINS_ENABLED="false"

# ─── Email (SMTP) ───────────────────────────────────────────────────────────
MAIL_FROM="no.reply@airegistry.mu"
EMAIL_FROM="no.reply@airegistry.mu"
EMAIL_SENDER_NAME="National AI Registry"
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="REPLACE"
SMTP_PASS="REPLACE"
CONTACT_EMAIL=""

# ─── Optional ───────────────────────────────────────────────────────────────
# OPERATOR_INBOX_EMAIL="desk@airegistry.mu"
# PUBLIC_CONTACT_URL="https://airegistry.mu/contact"
# ADMIN_HOME_URL="https://airegistry.mu/admin"

# Bootstrap seed credentials — set ONCE, then unset and re-deploy. Leaving these
# in the live env means the seed script will re-apply them every deploy.
# SEED_ADMIN_EMAIL="admin@airegistry.mu"
# SEED_ADMIN_PASSWORD=""
# SEED_PROVIDER_PASSWORD=""
