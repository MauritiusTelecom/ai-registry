{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "sovereign.catalog",
  "description": "Telemetry events emitted by the Sovereign portal /catalog route.",
  "events": [
    {
      "name": "sovereign.catalog.viewed",
      "trigger": "SovCatalog component mount.",
      "payload": {
        "type": "object",
        "required": ["totalCount"],
        "properties": {
          "totalCount":  { "type": "integer" },
          "tier1Count":  { "type": "integer" },
          "tier3Count":  { "type": "integer" },
          "highRiskCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "sovereign.catalog.list.fetched",
      "trigger": "GET /sovereign/catalog completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "sovereign.catalog.row.viewed",
      "trigger": "Each catalog row is rendered.",
      "payload": {
        "type": "object",
        "required": ["resourceId", "kind", "tier", "risk"],
        "properties": {
          "resourceId": { "type": "string" },
          "kind":       { "type": "string" },
          "tier":       { "type": "string" },
          "risk":       { "enum": ["low", "med", "high"] }
        }
      }
    },
    {
      "name": "sovereign.catalog.error",
      "trigger": "GET /sovereign/catalog returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status":  { "type": "integer" },
          "problem": { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
