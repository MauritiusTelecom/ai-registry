{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "sovereign.dashboard",
  "description": "Telemetry events emitted by the Sovereign portal dashboard route.",
  "events": [
    {
      "name": "sovereign.dashboard.viewed",
      "trigger": "SovDashboard component mount.",
      "payload": {
        "type": "object",
        "required": ["route", "summary"],
        "properties": {
          "route": { "const": "/" },
          "summary": {
            "type": "object",
            "properties": {
              "sovereignResources": { "type": "integer" },
              "crossBorderCalls":   { "type": "string" },
              "riskIndex":          { "type": "integer" },
              "openIncidents":      { "type": "integer" }
            }
          }
        }
      }
    },
    {
      "name": "sovereign.dashboard.action.open_national_report.clicked",
      "trigger": "User clicks the 'Open national report' header primary button."
    },
    {
      "name": "sovereign.dashboard.topology.node.hovered",
      "trigger": "User hovers a topology node (production-only; no hover state in v0.4).",
      "payload": {
        "type": "object",
        "required": ["nodeId", "kind"],
        "properties": {
          "nodeId": { "type": "string" },
          "kind":   { "enum": ["agent", "mcp", "tool", "model-ext"] }
        }
      }
    },
    {
      "name": "sovereign.dashboard.heatmap.cell.hovered",
      "trigger": "User hovers a heatmap cell (production-only).",
      "payload": {
        "type": "object",
        "required": ["sector", "tier", "count"],
        "properties": {
          "sector": { "type": "string" },
          "tier":   { "type": "string" },
          "count":  { "type": "integer" }
        }
      }
    },
    {
      "name": "sovereign.dashboard.risk.point.hovered",
      "trigger": "User hovers a risk timeline point (production-only).",
      "payload": {
        "type": "object",
        "required": ["day", "score"],
        "properties": {
          "day":   { "type": "string" },
          "score": { "type": "integer" }
        }
      }
    },
    {
      "name": "sovereign.dashboard.summary.fetched",
      "trigger": "GET /sovereign/summary completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms"],
        "properties": {
          "status": { "type": "integer" },
          "ms":     { "type": "integer", "minimum": 0 }
        }
      }
    },
    {
      "name": "sovereign.dashboard.topology.fetched",
      "trigger": "GET /sovereign/topology completes."
    },
    {
      "name": "sovereign.dashboard.heatmap.fetched",
      "trigger": "GET /sovereign/heatmap completes."
    },
    {
      "name": "sovereign.dashboard.risk.fetched",
      "trigger": "GET /sovereign/risk completes."
    },
    {
      "name": "sovereign.dashboard.error",
      "trigger": "Any of the dashboard endpoints returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
