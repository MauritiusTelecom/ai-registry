{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "sovereign.partners",
  "description": "Telemetry events emitted by the Sovereign portal /partners route. Read-only.",
  "events": [
    {
      "name": "sovereign.partners.viewed",
      "trigger": "SovPartners component mount.",
      "payload": {
        "type": "object",
        "required": ["totalCount", "pendingCount"],
        "properties": {
          "totalCount":   { "type": "integer" },
          "pendingCount": { "type": "integer", "description": "count(mou === 'pending')" }
        }
      }
    },
    {
      "name": "sovereign.partners.row.viewed",
      "trigger": "Each partner row renders.",
      "payload": {
        "type": "object",
        "required": ["name", "kind"],
        "properties": {
          "name": { "type": "string" },
          "kind": { "enum": ["regional", "sovereign", "intergov"] }
        }
      }
    },
    {
      "name": "sovereign.partners.list.fetched",
      "trigger": "GET /sovereign/partners completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "sovereign.partners.row.clicked",
      "trigger": "Production-only: user clicks a row to drill into the partner detail drawer.",
      "payload": {
        "type": "object",
        "required": ["name"],
        "properties": { "name": { "type": "string" } }
      }
    },
    {
      "name": "sovereign.partners.error",
      "trigger": "GET /sovereign/partners returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status":  { "type": "integer" },
          "problem": { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
