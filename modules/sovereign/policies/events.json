{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "sovereign.policies",
  "description": "Telemetry events emitted by the Sovereign portal /policies route. Read-only.",
  "events": [
    {
      "name": "sovereign.policies.viewed",
      "trigger": "SovPolicies component mount.",
      "payload": {
        "type": "object",
        "required": ["totalCount", "enforcedCount"],
        "properties": {
          "totalCount":    { "type": "integer" },
          "enforcedCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "sovereign.policies.row.viewed",
      "trigger": "Each policy row renders.",
      "payload": {
        "type": "object",
        "required": ["policyId", "scope", "enforced"],
        "properties": {
          "policyId": { "type": "string" },
          "scope":    { "type": "string" },
          "enforced": { "type": "boolean" }
        }
      }
    },
    {
      "name": "sovereign.policies.list.fetched",
      "trigger": "GET /sovereign/policies completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "sovereign.policies.error",
      "trigger": "GET /sovereign/policies returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status":  { "type": "integer" },
          "problem": { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
