{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "sovereign.risk",
  "description": "Telemetry events emitted by the Sovereign portal /risk route.",
  "events": [
    {
      "name": "sovereign.risk.viewed",
      "trigger": "SovRisk component mount.",
      "payload": {
        "type": "object",
        "required": ["latestScore", "weekCount"],
        "properties": {
          "latestScore": { "type": "integer" },
          "weekCount":   { "type": "integer" }
        }
      }
    },
    {
      "name": "sovereign.risk.fetched",
      "trigger": "GET /sovereign/risk completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms"],
        "properties": {
          "status": { "type": "integer" },
          "ms":     { "type": "integer", "minimum": 0 }
        }
      }
    },
    {
      "name": "sovereign.risk.week.hovered",
      "trigger": "User hovers a risk timeline point (production-only).",
      "payload": {
        "type": "object",
        "required": ["day", "score"],
        "properties": {
          "day":   { "type": "string" },
          "score": { "type": "integer" }
        }
      }
    },
    {
      "name": "sovereign.risk.week.clicked",
      "trigger": "User clicks a risk timeline point to drill in (production-only).",
      "payload": {
        "type": "object",
        "required": ["day"],
        "properties": { "day": { "type": "string" } }
      }
    },
    {
      "name": "sovereign.risk.heatmap.cell.hovered",
      "trigger": "User hovers a heatmap cell (production-only).",
      "payload": {
        "type": "object",
        "required": ["sector", "tier", "count"],
        "properties": {
          "sector": { "type": "string" },
          "tier":   { "type": "string" },
          "count":  { "type": "integer" }
        }
      }
    },
    {
      "name": "sovereign.risk.error",
      "trigger": "GET /sovereign/risk returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status":  { "type": "integer" },
          "problem": { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
