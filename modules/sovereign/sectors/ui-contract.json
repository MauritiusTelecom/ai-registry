{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "sovereign.sectors",
  "description": "Explicit UI contract for the Sovereign portal /sectors route.",

  "route": {
    "portal": "sovereign",
    "path": "/sectors",
    "html_entry": "portals/sovereign.html"
  },

  "shell_overrides": {
    "currentTitle": "Sectors",
    "breadcrumb": ["Sovereign", "National", "Sectors"],
    "active_sidebar_item": "sectors"
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title": "Sectors",
      "subtitle": "Coverage and growth across Mauritian government sectors.",
      "actions": []
    },

    "card_grid": {
      "container_class": "p-grid p-grid-3",
      "card_template": {
        "component": "p-card",
        "head": {
          "left": {
            "kind": "stack",
            "lines": [
              { "binding": "name", "class": "p-card-title" },
              { "binding": "tier", "class": "p-card-sub" }
            ]
          },
          "right": {
            "kind": "text",
            "class": "p-mono-val",
            "style": { "fontSize": 22 },
            "binding": "count"
          }
        },
        "growth_row": {
          "container_class": "p-row",
          "container_style": { "justifyContent": "space-between" },
          "left":  { "kind": "text", "class": "p-mono-key", "text": "growth (30d)" },
          "right": {
            "kind": "text",
            "class": "mono",
            "style": { "color": "#10b981", "fontSize": 12 },
            "binding": "growth",
            "production_color_rules": {
              "positive": "#10b981",
              "zero":     "var(--p-text-3)",
              "negative": "#ef4444"
            }
          }
        }
      }
    }
  },

  "icons_used": [],

  "interactions": [
    { "id": "card_click", "trigger": "card.click (production-only)", "effect": "navigate('/catalog?sector=' + name.toLowerCase())" }
  ],

  "empty_states": {
    "no_sectors": { "body_text": "Sector taxonomy not configured." }
  },

  "non_negotiables": [
    "PageHeader has NO action buttons.",
    "Page uses a 3-column card grid (p-grid p-grid-3).",
    "Each card has exactly: head (title + tier sub on left, big mono count on right) and a growth row (mono-key 'growth (30d)' + mono growth value).",
    "Big number font size is 22.",
    "Growth value is hard-coded #10b981 in v0.4 — production MUST branch on sign per the rules.",
    "Tier is rendered as p-card-sub TEXT (not as a p-tag chip).",
    "Sector name list is fixed in v0.4: Education, Finance, Health, Trade, Logistics, Agriculture.",
    "v0.4 cards are non-interactive — do NOT bind onClick until card click ships."
  ]
}
