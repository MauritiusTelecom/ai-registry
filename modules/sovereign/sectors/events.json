{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "sovereign.sectors",
  "description": "Telemetry events emitted by the Sovereign portal /sectors route.",
  "events": [
    {
      "name": "sovereign.sectors.viewed",
      "trigger": "SovSectors component mount.",
      "payload": {
        "type": "object",
        "required": ["sectorCount", "totalResources"],
        "properties": {
          "sectorCount":    { "type": "integer" },
          "totalResources": { "type": "integer" }
        }
      }
    },
    {
      "name": "sovereign.sectors.card.viewed",
      "trigger": "Each sector card renders.",
      "payload": {
        "type": "object",
        "required": ["name", "count", "tier"],
        "properties": {
          "name":   { "type": "string" },
          "count":  { "type": "integer" },
          "tier":   { "type": "string" },
          "growth": { "type": "string" }
        }
      }
    },
    {
      "name": "sovereign.sectors.card.clicked",
      "trigger": "User clicks a sector card (production-only; no click in v0.4).",
      "payload": {
        "type": "object",
        "required": ["name"],
        "properties": { "name": { "type": "string" } }
      }
    },
    {
      "name": "sovereign.sectors.fetched",
      "trigger": "GET /sovereign/sectors completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms"],
        "properties": {
          "status": { "type": "integer" },
          "ms":     { "type": "integer", "minimum": 0 }
        }
      }
    },
    {
      "name": "sovereign.sectors.error",
      "trigger": "GET /sovereign/sectors returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status":  { "type": "integer" },
          "problem": { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
