{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "public.docs",
  "description": "Explicit UI contract for the public marketing /docs route.",

  "route": {
    "site": "public",
    "path": "/docs",
    "html_entry_bundle_a": "index.html",
    "html_entry_bundle_b": "Sovereign AI Registry.html"
  },

  "shell_inherited_from": "modules/public/home/ui-contract.json",

  "page": {
    "page_hero": {
      "component": "PageHero",
      "class": "page-hero",
      "grid_bg_overlay": {
        "class": "grid-bg",
        "style": { "position": "absolute", "inset": 0, "opacity": 0.6, "zIndex": 0 }
      },
      "inner_style": { "position": "relative", "zIndex": 1 },
      "crumb": "Documentation · AIR-SPEC 0.4 MVP",
      "h1_lines": [
        "The technical ",
        { "kind": "gradient_span", "text": "specification" },
        "."
      ],
      "subtitle": "Everything you need to publish, resolve and audit listings against the v0.4 reference implementation at airegistry.mu.",
      "subtitle_style": { "marginTop": 18, "fontSize": 17, "maxWidth": 680, "color": "var(--text-2)" }
    },

    "section": {
      "class": "section",
      "container_style": { "paddingTop": 40 },
      "inner_grid_style": { "display": "grid", "gridTemplateColumns": "220px 1fr", "gap": 48 },

      "sticky_nav": {
        "wrap": "Reveal",
        "container_style": {
          "position": "sticky",
          "top": 100,
          "display": "flex",
          "flexDirection": "column",
          "gap": 4,
          "fontFamily": "IBM Plex Mono, monospace",
          "fontSize": 12
        },
        "links": [
          { "id": "overview",     "label": "Overview" },
          { "id": "air-id",       "label": "AIR-ID format" },
          { "id": "metadata",     "label": "Listing metadata" },
          { "id": "verification", "label": "Provider verification" },
          { "id": "review",       "label": "Review workflow" }
        ],
        "link_style": { "padding": "6px 10px", "borderRadius": 6, "color": "var(--text-2)" },
        "active_link_class_in_production": "active",
        "test_id_template": "public.docs.nav.${id}"
      },

      "sections_column_style": { "display": "flex", "flexDirection": "column", "gap": 32 },

      "section_block_template": {
        "wrap": "Reveal",
        "delay_template_ms": "i * 50",
        "outer": { "id_binding": "id" },
        "eyebrow": {
          "class": "eyebrow",
          "dot": true,
          "label_template": "§ ${NN} ${label}",
          "NN_format": "padStart(2, '0')",
          "section_sign": "§ (U+00A7)"
        },
        "h3": {
          "binding": "label",
          "style": { "marginTop": 12 }
        },
        "body": {
          "binding": "body",
          "style": { "marginTop": 8, "fontSize": 15, "lineHeight": 1.65 }
        },
        "code": {
          "tag": "pre",
          "style": {
            "marginTop": 14,
            "padding": 16,
            "background": "var(--code-bg)",
            "border": "1px solid var(--border)",
            "borderRadius": 10,
            "fontFamily": "IBM Plex Mono, monospace",
            "fontSize": 12.5,
            "color": "var(--text-2)",
            "overflow": "auto"
          },
          "template": "# example\nGET /.well-known/air-spec/${id}\n→ 200 OK  application/yaml",
          "notes": "The arrow is Unicode → (U+2192). Two spaces between '200 OK' and 'application/yaml'."
        }
      }
    }
  },

  "icons_used": [],

  "interactions": [
    { "id": "nav_anchor_click", "trigger_test_id_prefix": "public.docs.nav.", "effect": "preventDefault → element.scrollIntoView({behavior:'smooth'})" },
    { "id": "code_copy", "trigger": "Copy button per <pre> (production-only)", "effect": "navigator.clipboard.writeText(codeText)" }
  ],

  "non_negotiables": [
    "Page renders PageHero followed by a 2-column section: 220px sticky nav on the left, sections on the right.",
    "Section paddingTop is 40 (under the PageHero).",
    "Inner grid template is exactly '220px 1fr' with gap 48.",
    "Sticky nav uses position: sticky, top: 100; collapses with the right column under ~720px (production).",
    "Sticky nav font is IBM Plex Mono 12px.",
    "Each section block has Reveal delay = i * 50 ms.",
    "Eyebrow numbering uses padStart(2, '0') so 1 → '01' etc.",
    "Section sign in eyebrow is Unicode § (U+00A7); rightwards arrow in code block is Unicode → (U+2192).",
    "Five section ids are fixed: overview, air-id, metadata, verification, review.",
    "Sticky nav anchor clicks MUST be intercepted (preventDefault + smooth scroll) — bare href='#${id}' breaks the hash router."
  ]
}
