{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "public.ecosystem",
  "description": "Telemetry events emitted by the public marketing /ecosystem route. Anonymous; no PII.",
  "events": [
    {
      "name": "public.ecosystem.viewed",
      "trigger": "App mounts on hash '#/ecosystem'.",
      "payload": {
        "type": "object",
        "required": ["tierCount", "partnerCount"],
        "properties": {
          "tierCount":    { "type": "integer", "minimum": 0 },
          "partnerCount": { "type": "integer", "minimum": 0 }
        }
      }
    },
    {
      "name": "public.ecosystem.tier.revealed",
      "trigger": "A tier block enters the viewport (Reveal IntersectionObserver fires).",
      "payload": {
        "type": "object",
        "required": ["tier", "index"],
        "properties": {
          "tier":  { "type": "string" },
          "index": { "type": "integer", "minimum": 0 }
        }
      }
    },
    {
      "name": "public.ecosystem.partner.clicked",
      "trigger": "User clicks a partner glass card (production-only; no click in v0.4).",
      "payload": {
        "type": "object",
        "required": ["tier", "name"],
        "properties": {
          "tier": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    },
    {
      "name": "public.ecosystem.fetched",
      "trigger": "GET /public/ecosystem completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms"],
        "properties": {
          "status": { "type": "integer" },
          "ms":     { "type": "integer", "minimum": 0 }
        }
      }
    },
    {
      "name": "public.ecosystem.error",
      "trigger": "GET /public/ecosystem returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status":  { "type": "integer" },
          "problem": { "type": "string" }
        }
      }
    }
  ]
}
