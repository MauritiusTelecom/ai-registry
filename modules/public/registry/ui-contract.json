{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "public.registry",
  "description": "Explicit UI contract for the public marketing /registry route.",

  "route": {
    "site": "public",
    "path": "/registry",
    "html_entry_bundle_a": "index.html",
    "html_entry_bundle_b": "Sovereign AI Registry.html"
  },

  "shell_inherited_from": "modules/public/home/ui-contract.json",

  "page": {
    "page_hero": null,
    "section": {
      "id": "registry-section",
      "class": "section",
      "header": {
        "wrap": "Reveal",
        "class": "section-header",
        "eyebrow": { "text": "The Registry", "dot": true },
        "h2_lines": [
          "Discover what your nation can ",
          { "kind": "gradient_span", "text": "trust and integrate" },
          "."
        ],
        "lead_template": "The registry points to locally-relevant AI resources — never hosts them. Each listing carries a verifiable provider, a sovereignty review, and a stable AIR-ID under ${airId_token}.",
        "lead_air_token_class": "mono",
        "lead_air_token_style": { "color": "var(--text-2)" },
        "lead_air_token_text": "air://"
      },

      "toolbar": {
        "wrap": "Reveal",
        "class": "registry-toolbar",
        "search_input": {
          "class": "search-input",
          "icon": { "name": "search", "size": 15 },
          "placeholder": "Search resources, providers, AIR-IDs…",
          "kbd_hint": "⌘K",
          "binding": "query",
          "test_id": "public.registry.search"
        },
        "kind_tabs": {
          "class": "tabs",
          "items": [
            { "id": "all",   "label": "All resources", "icon": "layers" },
            { "id": "model", "label": "Models",        "icon": "cpu" },
            { "id": "agent", "label": "Agents",        "icon": "agent" },
            { "id": "skill", "label": "MCP skills",    "icon": "zap" },
            { "id": "tool",  "label": "Tools",         "icon": "flow" }
          ],
          "icon_size": 13,
          "active_class": "active",
          "count_pill_class": "tab-count",
          "binding": "activeKind",
          "test_id_template": "public.registry.tab.${id}"
        }
      },

      "filter_chips": {
        "wrap": "Reveal",
        "class": "filter-chips",
        "label_text": "Status",
        "label_style": {
          "fontFamily": "IBM Plex Mono, monospace",
          "fontSize": 11,
          "color": "var(--text-3)",
          "letterSpacing": "0.1em",
          "textTransform": "uppercase",
          "marginRight": 8
        },
        "chips": ["verified", "trusted", "active", "experimental", "isolated"],
        "active_class": "active",
        "single_select": true,
        "clear_button_label": "Clear filters",
        "clear_button_visible_when": "activeStatus !== null || query !== ''",
        "binding": "activeStatus",
        "test_id_template": "public.registry.chip.${status}"
      },

      "grid": {
        "class": "registry-grid",
        "card_template": {
          "wrap": "Reveal",
          "delay_template_ms": "i * 35",
          "component": "RegistryCard",
          "class": "r-card",
          "head": {
            "class": "r-card-head",
            "icon_square": { "class": "r-icon", "binding": "glyph" },
            "stack": {
              "lines": [
                { "binding": "title",    "class": "r-title" },
                { "binding": "provider", "class": "r-provider" }
              ]
            },
            "status_pill": {
              "class": "r-status",
              "modifier_class_template": "${row.status}",
              "dot_class": "status-dot",
              "label_binding": "status"
            }
          },
          "desc": { "class": "r-desc", "binding": "desc" },
          "meta": {
            "class": "r-meta",
            "rows": [
              { "label": "Context", "binding": "context" },
              { "label": "Latency", "binding": "latency" },
              { "label": "Region",  "binding": "region" },
              { "label": "License", "binding": "license" }
            ],
            "row_class": "r-meta-row",
            "label_class": "r-meta-label",
            "value_class": "r-meta-value"
          },
          "tags": {
            "class": "r-tags",
            "item_class": "tag",
            "binding": "tags"
          },
          "actions": {
            "class": "r-card-actions",
            "items": [
              { "label": "View",    "icon": "eye",  "icon_size": 12, "test_id": "public.registry.card.view" },
              { "label": "AIR-ID",  "icon": "doc",  "icon_size": 12, "test_id": "public.registry.card.air_id" },
              { "label": "Report",  "icon": "flag", "icon_size": 12, "extra_class": "btn-report", "onClick": "props.onReport(row)", "test_id": "public.registry.card.report" }
            ]
          }
        }
      },

      "empty_state": {
        "shown_when": "filtered.length === 0",
        "container_style": {
          "gridColumn": "1 / -1",
          "padding": 48,
          "textAlign": "center",
          "color": "var(--text-3)",
          "fontFamily": "IBM Plex Mono, monospace"
        },
        "text": "No resources match these filters."
      }
    }
  },

  "icons_used": ["search", "layers", "cpu", "agent", "zap", "flow", "eye", "doc", "flag"],

  "interactions": [
    { "id": "search",        "trigger": "input change",                    "effect": "setQuery → useMemo recompute" },
    { "id": "kind_tab",      "trigger_test_id_prefix": "public.registry.tab.",  "effect": "setActiveKind" },
    { "id": "status_chip",   "trigger_test_id_prefix": "public.registry.chip.", "effect": "setActiveStatus (toggle)" },
    { "id": "clear_filters", "trigger": "Clear filters button",            "effect": "setActiveStatus(null) + setQuery('')" },
    { "id": "card_view",     "trigger_test_id": "public.registry.card.view",   "effect": "navigate_to_external_detail (production)" },
    { "id": "card_air_id",   "trigger_test_id": "public.registry.card.air_id", "effect": "clipboard.writeText(airId)" },
    { "id": "card_report",   "trigger_test_id": "public.registry.card.report", "effect": "open_global_report_modal_with(card)" }
  ],

  "non_negotiables": [
    "When route === 'registry', app.jsx renders ONLY <RegistrySection> in the route slot — no PageHero, no extra wrapper.",
    "Section header 'gradient-text' span text is exactly 'trust and integrate' (no terminating space; the period is outside the span).",
    "Search placeholder is exactly 'Search resources, providers, AIR-IDs…' (note Unicode horizontal ellipsis U+2026).",
    "Kind tab order is fixed: All resources → Models → Agents → MCP skills → Tools.",
    "Status chip order is fixed: verified → trusted → active → experimental → isolated.",
    "Status chip selection is single — clicking the same chip again toggles it off; not multi-select in v0.4.",
    "Clear filters button only appears when activeStatus or query is non-empty; it does NOT reset activeKind.",
    "Card stagger delay is exactly i * 35 ms.",
    "Card actions order is fixed: View → AIR-ID → Report.",
    "Empty state message is 'No resources match these filters.' rendered in mono with 48px padding.",
    "Even rows with status === 'isolated' MUST appear in the public catalog.",
    "Search matches title + provider + desc + tags (case-insensitive); production should add airId."
  ]
}
