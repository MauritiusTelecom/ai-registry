{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "public.registry",
  "description": "Telemetry events emitted by the public marketing /registry route. Anonymous; no PII.",
  "events": [
    {
      "name": "public.registry.viewed",
      "trigger": "App mounts on hash '#/registry'.",
      "payload": {
        "type": "object",
        "required": ["bundle", "rowCount"],
        "properties": {
          "bundle":   { "enum": ["A", "B"] },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "public.registry.search.changed",
      "trigger": "User types in the search input (debounced 250ms in production).",
      "payload": {
        "type": "object",
        "required": ["queryLength"],
        "properties": { "queryLength": { "type": "integer", "minimum": 0 } }
      }
    },
    {
      "name": "public.registry.kind_tab.clicked",
      "trigger": "User selects a kind tab.",
      "payload": {
        "type": "object",
        "required": ["kind"],
        "properties": { "kind": { "enum": ["all", "model", "agent", "skill", "tool"] } }
      }
    },
    {
      "name": "public.registry.status_chip.toggled",
      "trigger": "User clicks a status chip.",
      "payload": {
        "type": "object",
        "required": ["status", "active"],
        "properties": {
          "status": { "enum": ["verified", "trusted", "active", "experimental", "isolated"] },
          "active": { "type": "boolean" }
        }
      }
    },
    {
      "name": "public.registry.filters.cleared",
      "trigger": "User clicks the 'Clear filters' chip."
    },
    {
      "name": "public.registry.card.action_clicked",
      "trigger": "User clicks View / AIR-ID / Report on a card.",
      "payload": {
        "type": "object",
        "required": ["airId", "action"],
        "properties": {
          "airId":  { "type": "string" },
          "action": { "enum": ["view", "air_id", "report"] }
        }
      }
    },
    {
      "name": "public.registry.card.air_id.copied",
      "trigger": "navigator.clipboard.writeText for the AIR-ID string succeeds.",
      "payload": {
        "type": "object",
        "required": ["airId"],
        "properties": { "airId": { "type": "string" } }
      }
    },
    {
      "name": "public.registry.empty_state.viewed",
      "trigger": "Filtered list is empty and the empty-state message renders.",
      "payload": {
        "type": "object",
        "required": ["filters"],
        "properties": {
          "filters": {
            "type": "object",
            "properties": {
              "kind":   { "type": "string" },
              "status": { "type": ["string", "null"] },
              "queryLength": { "type": "integer" }
            }
          }
        }
      }
    },
    {
      "name": "public.registry.list.fetched",
      "trigger": "GET /public/registry completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "public.registry.error",
      "trigger": "GET /public/registry returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status":  { "type": "integer" },
          "problem": { "type": "string" }
        }
      }
    }
  ]
}
