{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "public.home",
  "description": "Explicit UI contract for the public marketing home route. Production must render every named element with the listed text, classes, and binding so visual regression vs. the prototype is mechanical.",

  "route": {
    "site": "public",
    "path": "/home",
    "html_entry_bundle_a": "index.html",
    "html_entry_bundle_b": "Sovereign AI Registry.html",
    "default_route_when_hash_empty": "home"
  },

  "design_tokens": {
    "theme_attribute": "data-theme on documentElement (dark | light)",
    "theme_storage_key": "sar-theme",
    "tweaks_storage_key": "sar-tweaks",
    "palettes": [
      { "id": 0, "label": "Sovereign Blue", "primary_rgb": "59,130,246", "secondary_rgb": "6,182,212",   "tertiary_rgb": "168,85,247" },
      { "id": 1, "label": "Pacific Teal",   "primary_rgb": "20,184,166", "secondary_rgb": "52,211,153",  "tertiary_rgb": "14,165,233" },
      { "id": 2, "label": "Coral Magenta",  "primary_rgb": "236,72,153", "secondary_rgb": "244,114,182", "tertiary_rgb": "168,85,247" },
      { "id": 3, "label": "Solar Amber",    "primary_rgb": "245,158,11", "secondary_rgb": "251,191,36",  "tertiary_rgb": "239,68,68" }
    ],
    "density_section_pad_map": { "compact": "80px", "balanced": "120px", "spacious": "160px" },
    "css_custom_properties_used": [
      "--primary", "--primary-rgb", "--secondary", "--secondary-rgb", "--tertiary", "--tertiary-rgb",
      "--text", "--text-2", "--text-3", "--bg", "--bg-radial",
      "--border", "--hairline", "--code-bg",
      "--grad-text", "--grad-accent", "--grad-border", "--grad-glow",
      "--section-pad"
    ],
    "transitions": {
      "theme": "background-color 240ms ease, color 240ms ease",
      "reveal": "opacity / translateY 700ms cubic-bezier(.2,.8,.2,1)"
    }
  },

  "shell": {
    "top_nav": {
      "component": "TopNav",
      "logo": { "mark": "small svg mark", "text": "Sovereign Registry" },
      "links": [
        { "id": "home",       "label": "Home" },
        { "id": "registry",   "label": "Registry" },
        { "id": "ecosystem",  "label": "Ecosystem" },
        { "id": "governance", "label": "Governance" },
        { "id": "docs",       "label": "Documentation" },
        { "id": "contact",    "label": "Contact" }
      ],
      "right_slot": [
        { "kind": "theme_toggle" },
        { "kind": "cta", "label": "Log In", "navigate": "contact" },
        { "kind": "mobile_menu_button", "below_breakpoint_px": 720 }
      ]
    },
    "footer_bundle_a": { "described_in": "modules/landing/product.md (Bundle A — Footer section)" },
    "footer_bundle_b": { "described_in": "modules/landing/product.md (Bundle B — Footer section)" },
    "report_modal": { "described_in": "components/modal.jsx; flows in this module's flows.md" },
    "tweaks_panel": { "described_in": "tweaks-panel.jsx; design-time only" }
  },

  "page_sections_in_order": [
    {
      "id": "hero",
      "component": "Hero",
      "eyebrow": "v0.4 · airegistry.mu",
      "h1_lines": [ "The Sovereign", { "kind": "gradient_span", "text": "AI Registry." } ],
      "subtitle": "Govern, orchestrate, and monitor trusted AI agents, models, and MCP infrastructure from a unified sovereign platform — built for nations, regulators, and the enterprises they depend on.",
      "ctas": [
        { "kind": "Btn", "variant": "primary",   "label": "Launch Registry",   "navigate": "registry",  "icon": "arrow-right",     "test_id": "public.home.cta.launch_registry" },
        { "kind": "Btn", "variant": "secondary", "label": "Explore Ecosystem", "navigate": "ecosystem", "test_id": "public.home.cta.explore_ecosystem" }
      ],
      "meta_row": [
        { "kind": "status_dot_text", "text": "All systems nominal" },
        { "kind": "text", "text": "SOC 2 · ISO 27001 · FedRAMP High", "style": { "color": "var(--secondary)" } },
        { "kind": "text", "text": "build 2026.05.07-r3" }
      ],
      "float_cards": [
        { "kind": "AI Agent", "name": "agent.compliance-watch", "status": "Active",   "color": "#10b981",          "provider": "Internal",   "delay": "0s" },
        { "kind": "AI Model", "name": "claude-sonnet-4.5",      "status": "Verified", "color": "var(--secondary)", "provider": "Anthropic",  "delay": "1.5s" },
        { "kind": "MCP Skill","name": "mcp/treasury-ledger",    "status": "Trusted",  "color": "var(--tertiary)",  "provider": "Government", "delay": "3s" }
      ],
      "globe": { "component": "Globe", "motion_intensity_binding": "tweaks.motionIntensity" }
    },
    { "id": "metrics", "component": "MetricsBar", "metrics_described_in": "data-model.md MetricsBar table" },
    { "id": "registry", "component": "RegistrySection", "described_in": "modules/public/registry/" },
    { "id": "governance", "component": "GovernanceSection", "described_in": "modules/public/governance/" },
    { "id": "orchestration", "bundle_a_component": "OrchestrationSection", "bundle_b_component": "Orchestration", "described_in": "product.md Orchestration sections" },
    { "id": "promo", "bundle_a_component": "PromoBanner", "bundle_b_component": "Promo", "described_in": "product.md Promo sections" },
    { "id": "faq", "bundle_a_component": "FaqSection", "bundle_b_component": "FAQ", "single_open_accordion": true, "described_in": "product.md FAQ sections" }
  ],

  "icons_used_on_this_page": [
    "arrow-right", "arrow-up-right", "search", "shield", "globe", "lock", "eye",
    "doc", "cpu", "agent", "check", "plus", "x", "sun", "moon", "menu", "zap", "layers", "flow"
  ],

  "interactions": [
    { "id": "launch_registry",   "trigger_test_id": "public.home.cta.launch_registry",   "effect": "navigate", "to": "registry" },
    { "id": "explore_ecosystem", "trigger_test_id": "public.home.cta.explore_ecosystem", "effect": "navigate", "to": "ecosystem" },
    { "id": "report_open",       "trigger": "registry card 'Report' action",             "effect": "open_report_modal" },
    { "id": "report_submit",     "trigger": "ReportModal Submit button",                  "effect": "POST /public/report" },
    { "id": "faq_toggle",        "trigger": "FAQ row click",                              "effect": "toggle_open_single_accordion" }
  ],

  "non_negotiables": [
    "Vertical section order is fixed: Hero → MetricsBar → RegistrySection → GovernanceSection → Orchestration → Promo → FAQ. Footer renders below.",
    "Hero gradient span class is `gradient-text` and uses `var(--grad-text)` via background-clip.",
    "MetricsBar count-up duration is 1600ms across all six cells; the Uptime row uses float display (e.g. '99.97'), others use integer.",
    "Float card animation is `drift-y 7s ease-in-out infinite`; per-card delays 0s / 1.5s / 3s.",
    "Globe motion intensity is bound to tweaks.motionIntensity (0..3); 0 slows but does not freeze.",
    "Tweaks panel is design-time only — production builds MUST omit it.",
    "Theme storage key is `sar-theme`; tweaks storage key is `sar-tweaks`.",
    "TopNav `Log In` CTA navigates to `contact` in v0.4; production swaps to OIDC.",
    "Bundle A renders OrchestrationSection / PromoBanner / FaqSection from orchestration.jsx + promo-faq-footer.jsx; Bundle B renders Orchestration / Promo / FAQ from sections.jsx. Don't mix bundles within one served page.",
    "Eyebrow dot uses @keyframes pulse 2.6s ease-in-out infinite.",
    "Reveal sections use IntersectionObserver threshold 0.12 and 700ms cubic-bezier(.2,.8,.2,1) transition."
  ]
}
