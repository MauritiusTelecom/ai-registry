{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "public.contact",
  "description": "Explicit UI contract for the public marketing /contact route.",

  "route": {
    "site": "public",
    "path": "/contact",
    "html_entry_bundle_a": "index.html",
    "html_entry_bundle_b": "Sovereign AI Registry.html"
  },

  "shell_inherited_from": "modules/public/home/ui-contract.json",

  "page": {
    "page_hero": {
      "component": "PageHero",
      "class": "page-hero",
      "grid_bg_overlay": {
        "class": "grid-bg",
        "style": { "position": "absolute", "inset": 0, "opacity": 0.6, "zIndex": 0 }
      },
      "inner_style": { "position": "relative", "zIndex": 1 },
      "crumb": "Contact · Talk to the operator",
      "h1_lines": [
        "Get in ",
        { "kind": "gradient_span", "text": "touch" },
        "."
      ],
      "subtitle": "Submit a resource, request review, report an issue, or talk to the team about standing up a registry in your jurisdiction.",
      "subtitle_style": { "marginTop": 18, "fontSize": 17, "maxWidth": 680, "color": "var(--text-2)" }
    },

    "section": {
      "class": "section",
      "container_style": { "paddingTop": 40 },
      "grid_class": "contact-grid",

      "left_column": {
        "wrap": "Reveal",
        "class": "contact-info-block",
        "rows": [
          { "kind": "row", "icon": "mail",  "icon_size": 16, "label": "Email",         "value": "hello@airegistry.mu" },
          { "kind": "row", "icon": "phone", "icon_size": 16, "label": "Operator desk", "value": "+230 460 0400" },
          { "kind": "row", "icon": "pin",   "icon_size": 16, "label": "Office",        "value_html": "Cyber City, Ebène<br/>Republic of Mauritius" },
          {
            "kind": "block",
            "container_style": { "paddingTop": 8, "borderTop": "1px dashed var(--border)" },
            "label": "Hours",
            "body_style": { "fontSize": 13.5, "color": "var(--text-2)", "marginTop": 6 },
            "body": "Mon–Fri · 09:00–17:30 · GMT+4"
          },
          {
            "kind": "block",
            "container_style": { "paddingTop": 8 },
            "label": "Status",
            "body_style": { "fontSize": 13.5, "marginTop": 6, "display": "inline-flex", "alignItems": "center", "gap": 8 },
            "body_template": "<span class=\"status-dot\"></span> All systems nominal · 99.97% 90-day SLO"
          }
        ],
        "row_class": "contact-info-row",
        "icon_class": "contact-info-icon",
        "label_class": "contact-info-label",
        "value_class": "contact-info-value"
      },

      "right_column": {
        "wrap": "Reveal",
        "delay_ms": 120,
        "class": "contact-form-block",
        "form_view": {
          "shown_when": "sent === false",
          "form_attrs": { "noValidate": true, "onSubmit": "submit" },
          "fields_in_order": [
            {
              "kind": "field-row",
              "class": "field-row",
              "items": [
                { "kind": "input",    "label": "Full name",    "binding": "name",  "placeholder": "Jane Doe",      "test_id": "public.contact.field.name" },
                { "kind": "input",    "label": "Organisation", "binding": "org",   "placeholder": "Ministry of …", "test_id": "public.contact.field.org" }
              ]
            },
            { "kind": "input",    "label": "Email",   "input_type": "email", "binding": "email", "placeholder": "you@org.mu", "test_id": "public.contact.field.email" },
            { "kind": "select",   "label": "Topic",   "binding": "topic", "default_value": "general",
              "options": [
                { "value": "general",      "label": "General enquiry" },
                { "value": "submit",       "label": "Submit a resource" },
                { "value": "review",       "label": "Request a review" },
                { "value": "report",       "label": "Report an issue" },
                { "value": "jurisdiction", "label": "Standing up a registry" },
                { "value": "press",        "label": "Press / media" }
              ],
              "test_id": "public.contact.field.topic"
            },
            { "kind": "textarea", "label": "Message", "binding": "message", "placeholder": "Tell us what you need…", "test_id": "public.contact.field.message" },
            {
              "kind": "submit-row",
              "container_style": { "display": "flex", "gap": 8, "justifyContent": "flex-end", "alignItems": "center", "marginTop": 8 },
              "left_text": {
                "style": { "fontFamily": "IBM Plex Mono, monospace", "fontSize": 11, "color": "var(--text-3)", "marginRight": "auto" },
                "text": "We reply within 2 working days."
              },
              "submit_button": {
                "kind": "Btn",
                "variant": "primary",
                "type": "submit",
                "label": "Send message",
                "icon": "arrow-right",
                "icon_size": 13,
                "test_id": "public.contact.submit"
              }
            }
          ],
          "field_class": "field",
          "field_error_class": "error",
          "field_error_text_class": "field-error",
          "validation_rules": {
            "name":    { "rule": "name.trim().length >= 2",         "error": "Name required" },
            "org":     { "rule": "org.trim().length >= 2",          "error": "Organisation required" },
            "email":   { "rule": "/^\\S+@\\S+\\.\\S+$/.test(email)", "error": "Valid email required" },
            "message": { "rule": "message.trim().length >= 16",     "error": "Tell us a bit more (≥16 chars)" }
          }
        },

        "success_view": {
          "shown_when": "sent === true",
          "blocks": [
            {
              "kind": "form-success",
              "class": "form-success",
              "icon": "check",
              "icon_size": 16,
              "text": "Message received. We respond within 2 working days."
            },
            {
              "kind": "Btn",
              "variant": "secondary",
              "label": "Send another",
              "style": { "marginTop": 18 },
              "onClick": "setSent(false); setForm({ name:'', org:'', email:'', topic:'general', message:'' });",
              "test_id": "public.contact.send_another"
            }
          ]
        }
      }
    }
  },

  "icons_used": ["mail", "phone", "pin", "check", "arrow-right"],

  "interactions": [
    { "id": "submit",          "trigger_test_id": "public.contact.submit",        "effect": "validate_then_POST_/public/contact_then_setSent(true)" },
    { "id": "send_another",    "trigger_test_id": "public.contact.send_another",  "effect": "setSent(false) + reset_form" }
  ],

  "non_negotiables": [
    "Page renders PageHero followed by a 2-column .contact-grid (left .contact-info-block + right .contact-form-block).",
    "Section paddingTop is 40.",
    "Hero crumb uses Unicode middle dot U+00B7: 'Contact · Talk to the operator'.",
    "Hero gradient span text is exactly 'touch' (no terminating space; period is outside the span).",
    "Left column reveals with no delay; right column reveals with delay 120 ms.",
    "Contact info row order is fixed: Email → Operator desk → Office → Hours → Status.",
    "Office value uses an HTML <br/> between 'Cyber City, Ebène' and 'Republic of Mauritius'.",
    "Hours value uses Unicode en dash U+2013 between 'Mon' and 'Fri', and between '09:00' and '17:30'; middle dots U+00B7 separate phrases.",
    "Hours / Status blocks are separated from the info rows by a 1px dashed top border.",
    "Form noValidate attribute is set; native browser validation is disabled.",
    "Field validation is exact per the rules table; error messages are reproduced verbatim including the Unicode ≥ (U+2265) in the message error.",
    "Topic select default value is 'general'.",
    "Submit row left-justifies a mono note 'We reply within 2 working days.' and right-justifies the primary submit button with arrow-right icon (size 13).",
    "Success view uses .form-success block with check icon (size 16), success message, and a secondary 'Send another' button (marginTop 18).",
    "'Send another' resets BOTH sent (to false) AND the form state (to initial values)."
  ]
}
