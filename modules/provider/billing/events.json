{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "provider.billing",
  "description": "Telemetry events emitted by the Provider portal /billing route.",
  "events": [
    {
      "name": "provider.billing.viewed",
      "trigger": "ProvBilling component mount.",
      "payload": {
        "type": "object",
        "required": ["totalCount", "tier"],
        "properties": {
          "totalCount": { "type": "integer" },
          "tier":       { "type": "string", "description": "Tier of the most recent statement." }
        }
      }
    },
    {
      "name": "provider.billing.list.fetched",
      "trigger": "GET /provider/billing completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "provider.billing.statement.viewed",
      "trigger": "User opens a statement detail (production-only row click).",
      "payload": {
        "type": "object",
        "required": ["periodIso"],
        "properties": { "periodIso": { "type": "string" } }
      }
    },
    {
      "name": "provider.billing.invoice.downloaded",
      "trigger": "GET /provider/billing/{periodIso}/invoice.pdf returns 200 (production-only).",
      "payload": {
        "type": "object",
        "required": ["periodIso"],
        "properties": { "periodIso": { "type": "string" } }
      }
    },
    {
      "name": "provider.billing.statement.disputed",
      "trigger": "POST /provider/billing/{periodIso}/dispute succeeds (production-only).",
      "payload": {
        "type": "object",
        "required": ["periodIso"],
        "properties": { "periodIso": { "type": "string" } }
      }
    },
    {
      "name": "provider.billing.error",
      "trigger": "Any of the billing endpoints returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
