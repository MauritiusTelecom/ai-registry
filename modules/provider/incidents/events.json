{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "provider.incidents",
  "description": "Telemetry events emitted by the Provider portal /incidents route.",
  "events": [
    {
      "name": "provider.incidents.viewed",
      "trigger": "ProvIncidents component mount.",
      "payload": {
        "type": "object",
        "required": ["totalCount", "openCount"],
        "properties": {
          "totalCount": { "type": "integer" },
          "openCount":  { "type": "integer" }
        }
      }
    },
    {
      "name": "provider.incidents.action.report_incident.clicked",
      "trigger": "User clicks 'Report incident' header primary button."
    },
    {
      "name": "provider.incidents.action.report_incident.submitted",
      "trigger": "Report-incident modal submits successfully (POST /provider/incidents 201).",
      "payload": {
        "type": "object",
        "required": ["incidentId", "resource", "kind", "severity"],
        "properties": {
          "incidentId": { "type": "string" },
          "resource":   { "type": "string" },
          "kind":       { "type": "string" },
          "severity":   { "enum": ["high", "med", "low"] }
        }
      }
    },
    {
      "name": "provider.incidents.list.fetched",
      "trigger": "GET /provider/incidents completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "provider.incidents.incident.investigating",
      "trigger": "POST /provider/incidents/{id}/investigate succeeds (production-only).",
      "payload": {
        "type": "object",
        "required": ["incidentId"],
        "properties": { "incidentId": { "type": "string" } }
      }
    },
    {
      "name": "provider.incidents.incident.resolved",
      "trigger": "POST /provider/incidents/{id}/resolve succeeds (production-only).",
      "payload": {
        "type": "object",
        "required": ["incidentId"],
        "properties": { "incidentId": { "type": "string" } }
      }
    },
    {
      "name": "provider.incidents.incident.reopened",
      "trigger": "POST /provider/incidents/{id}/reopen succeeds (production-only).",
      "payload": {
        "type": "object",
        "required": ["incidentId"],
        "properties": { "incidentId": { "type": "string" } }
      }
    },
    {
      "name": "provider.incidents.incident.public_changed",
      "trigger": "POST /provider/incidents/{id}/public succeeds (production-only).",
      "payload": {
        "type": "object",
        "required": ["incidentId", "public"],
        "properties": {
          "incidentId": { "type": "string" },
          "public":     { "type": "boolean" }
        }
      }
    },
    {
      "name": "provider.incidents.error",
      "trigger": "Any of the incidents endpoints returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
