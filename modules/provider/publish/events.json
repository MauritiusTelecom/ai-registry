{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "provider.publish",
  "description": "Telemetry events emitted by the Provider portal /publish wizard.",
  "events": [
    {
      "name": "provider.publish.viewed",
      "trigger": "ProvPublish component mount.",
      "payload": {
        "type": "object",
        "properties": {
          "draftId":   { "type": "string", "description": "Present if resuming an existing draft." },
          "stepShown": { "type": "integer", "minimum": 1, "maximum": 5 }
        }
      }
    },
    {
      "name": "provider.publish.step.advanced",
      "trigger": "User clicks 'Continue' to move to the next step.",
      "payload": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "integer", "minimum": 1, "maximum": 5 },
          "to":   { "type": "integer", "minimum": 1, "maximum": 5 }
        }
      }
    },
    {
      "name": "provider.publish.draft.saved",
      "trigger": "POST /provider/drafts (201) or PATCH /provider/drafts/{id} (200) succeeds.",
      "payload": {
        "type": "object",
        "required": ["draftId", "step"],
        "properties": {
          "draftId": { "type": "string" },
          "step":    { "type": "integer", "minimum": 1, "maximum": 5 }
        }
      }
    },
    {
      "name": "provider.publish.checks.run",
      "trigger": "POST /provider/drafts/{id}/checks completes.",
      "payload": {
        "type": "object",
        "required": ["draftId", "passed", "failed"],
        "properties": {
          "draftId": { "type": "string" },
          "passed":  { "type": "integer", "minimum": 0 },
          "failed":  { "type": "integer", "minimum": 0 }
        }
      }
    },
    {
      "name": "provider.publish.verification.challenge_issued",
      "trigger": "POST /provider/drafts/{id}/verification/challenge succeeds.",
      "payload": {
        "type": "object",
        "required": ["draftId", "proofChannel"],
        "properties": {
          "draftId":      { "type": "string" },
          "proofChannel": { "enum": ["dns-txt", "signed-manifest", "https-callback"] }
        }
      }
    },
    {
      "name": "provider.publish.submitted",
      "trigger": "POST /provider/drafts/{id}/submit accepted (202).",
      "payload": {
        "type": "object",
        "required": ["draftId", "resourceId", "version", "submissionId"],
        "properties": {
          "draftId":      { "type": "string" },
          "resourceId":   { "type": "string" },
          "version":      { "type": "string" },
          "submissionId": { "type": "string" }
        }
      }
    },
    {
      "name": "provider.publish.action.save_draft.clicked",
      "trigger": "User clicks the 'Save draft' ghost button."
    },
    {
      "name": "provider.publish.action.run_checks.clicked",
      "trigger": "User clicks the 'Run local checks' secondary button."
    },
    {
      "name": "provider.publish.action.continue.clicked",
      "trigger": "User clicks the 'Continue' primary button."
    },
    {
      "name": "provider.publish.error",
      "trigger": "Any of the publish endpoints returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
