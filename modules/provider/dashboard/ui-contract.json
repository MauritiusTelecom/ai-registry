{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "provider.dashboard",
  "description": "Explicit UI contract for the Provider portal dashboard route.",

  "route": {
    "portal": "provider",
    "path": "/",
    "html_entry": "portals/provider.html",
    "default_path_when_hash_empty": "/"
  },

  "design_tokens_inherited_from": "modules/admin/dashboard/ui-contract.json",

  "shell": {
    "component": "PortalShell",
    "props": {
      "role": "provider",
      "portalLabel": "Provider",
      "portalIcon": "layers",
      "currentTitle": "Dashboard",
      "breadcrumb": ["Provider", "Dashboard"]
    },
    "sidebar": {
      "logo_text": "AI Registry",
      "logo_sub_label": "Provider",
      "logo_sub_icon": "layers",
      "items": [
        { "id": "home",        "label": "Dashboard",     "icon": "home",     "path": "/" },
        { "divider": true, "id": "div_pub", "label": "Publishing" },
        { "id": "resources",   "label": "My resources",  "icon": "layers",   "path": "/resources" },
        { "id": "publish",     "label": "Publish",       "icon": "plus",     "path": "/publish" },
        { "id": "submissions", "label": "Submissions",   "icon": "inbox",    "path": "/submissions", "badge": "2" },
        { "divider": true, "id": "div_obs", "label": "Observe" },
        { "id": "analytics",   "label": "Analytics",     "icon": "activity", "path": "/analytics" },
        { "id": "incidents",   "label": "Incidents",     "icon": "flag",     "path": "/incidents", "badge": "1" },
        { "divider": true, "id": "div_org", "label": "Organisation" },
        { "id": "keys",        "label": "API keys",      "icon": "key",      "path": "/keys" },
        { "id": "team",        "label": "Team",          "icon": "users",    "path": "/team" },
        { "id": "billing",     "label": "Billing",       "icon": "database", "path": "/billing" },
        { "id": "docs",        "label": "Docs",          "icon": "doc",      "path": "/docs" },
        { "id": "settings",    "label": "Settings",      "icon": "settings", "path": "/settings" }
      ]
    }
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title_template": "${providerName} — Provider portal",
      "title_default":  "eduMu — Provider portal",
      "subtitle":       "Publish, monitor and iterate on resources you provide to the registry.",
      "actions": [
        { "kind": "Btn", "variant": "secondary", "icon": "arrow-up-right", "label": "View public profile", "test_id": "provider.dashboard.action.public_profile" },
        { "kind": "Btn", "variant": "primary",   "icon": "plus",            "label": "Publish resource",    "test_id": "provider.dashboard.action.publish_resource" }
      ]
    },

    "stat_grid": {
      "container_class": "p-grid p-grid-4",
      "container_style": { "marginBottom": 20 },
      "cards": [
        { "label": "Resources live",    "value": "3",      "delta": "+1",   "deltaTone": "pos", "sub": "published",  "icon": "layers",   "test_id": "provider.dashboard.stat.resourcesLive" },
        { "label": "Calls (7d)",        "value": "21.5k",  "delta": "+12%", "deltaTone": "pos", "sub": "vs last 7d", "icon": "activity", "test_id": "provider.dashboard.stat.calls7d" },
        { "label": "Uptime",            "value": "99.97%", "delta": "0",    "deltaTone": "neu", "sub": "90d",        "icon": "pulse",    "test_id": "provider.dashboard.stat.uptime90d" },
        { "label": "Open submissions",  "value": "2",      "delta": "+1",   "deltaTone": "neu", "sub": "in review",  "icon": "check",    "test_id": "provider.dashboard.stat.openSubmissions" }
      ]
    },

    "split_row": {
      "container_class": "p-grid p-grid-2",
      "container_style": { "marginBottom": 20, "gridTemplateColumns": "2fr 1fr" },
      "left_card": {
        "component": "p-card",
        "head": {
          "title": "Weekly traffic",
          "sub": "calls per resource kind",
          "right": {
            "kind": "legend",
            "items": [
              { "label": "mcp",   "swatch_token": "var(--primary)",   "swatch_shape": "square_rounded_2" },
              { "label": "tool",  "swatch_token": "var(--secondary)", "swatch_shape": "square_rounded_2" },
              { "label": "agent", "swatch_token": "var(--tertiary)",  "swatch_shape": "square_rounded_2" }
            ],
            "style": { "fontSize": 11, "color": "var(--p-text-3)", "gap": 14 }
          }
        },
        "body": {
          "component": "UsageChart",
          "viewBox": "0 0 720 220",
          "padding": 26,
          "days": 7,
          "y_max": 2500,
          "grid_lines": 5,
          "grid_stroke": "var(--p-border)",
          "grid_stroke_width": 0.8,
          "grid_dash": "2 4",
          "bar_corner_radius": 2,
          "bar_order": ["mcp", "tool", "agent"],
          "agent_height_multiplier": 6,
          "day_label": {
            "font_family": "IBM Plex Mono",
            "font_size":   10,
            "fill":        "var(--p-text-3)"
          }
        }
      },
      "right_card": {
        "component": "p-card",
        "head": {
          "title": "Open submissions",
          "right_link": { "label": "All", "href": "#/submissions", "class": "p-link", "test_id": "provider.dashboard.submissions.all" }
        },
        "body": {
          "kind": "list",
          "filter": "status !== 'approved'",
          "limit": null,
          "row_template": {
            "title_field": "target",
            "title_class": "p-cell-strong",
            "title_style": { "fontSize": 13 },
            "meta_template": "${stage} · ${age}",
            "meta_class": "p-cell-meta",
            "right": { "kind": "renderer", "renderer": "StatusPill", "props": { "status": "row.status" } },
            "row_border_bottom": "1px solid var(--p-border-soft)",
            "row_padding": "8px 0"
          }
        }
      }
    }
  },

  "icons": {
    "renderer": "PIcon (portal-shell.jsx)",
    "default_size": 16,
    "default_stroke": 1.6,
    "names_used_on_this_page": [
      "home", "layers", "plus", "inbox", "activity", "flag",
      "key", "users", "database", "doc", "settings",
      "arrow-up-right", "pulse", "check"
    ]
  },

  "status_pill_states_used_on_this_page": [
    { "name": "pending",  "applied_via": "raw_status_pass_through" },
    { "name": "review",   "applied_via": "raw_status_pass_through" }
  ],

  "interactions": [
    { "id": "view_public_profile", "trigger_test_id": "provider.dashboard.action.public_profile",   "effect": "open_external_url", "url_template": "https://airegistry.mu/providers/${providerSlug}" },
    { "id": "publish_resource",    "trigger_test_id": "provider.dashboard.action.publish_resource", "effect": "navigate",          "to": "/publish" },
    { "id": "submissions_all",     "trigger_test_id": "provider.dashboard.submissions.all",         "effect": "navigate",          "to": "/submissions" }
  ],

  "empty_states": {
    "no_traffic":         { "card": "left_card", "body_text": "No traffic yet. Publish your first resource to start seeing usage.", "cta_label": "Publish resource", "cta_to": "/publish" },
    "no_open_submissions":{ "card": "right_card", "body_text": "No open submissions. Quiet day." }
  },

  "error_states": {
    "fetch_failed": {
      "card_body_replacement": {
        "title": "Couldn't load",
        "cta_label": "Try again",
        "telemetry_event": "provider.dashboard.error"
      }
    }
  },

  "non_negotiables": [
    "Page title is templated per active provider; the prototype value 'eduMu — Provider portal' is the v0.4 stand-in.",
    "StatCard order is fixed: Resources live → Calls (7d) → Uptime → Open submissions.",
    "Split row uses gridTemplateColumns '2fr 1fr'.",
    "Chart legend swatches are SQUARE with borderRadius 2 (NOT round, unlike admin dashboard).",
    "Chart padding is 26 (NOT 24, unlike admin dashboard).",
    "Agent series height MUST be multiplied by 6 in the SVG renderer.",
    "Open submissions filter is `status !== 'approved'` and is NOT sliced — all matching rows are shown.",
    "Right link label on Open submissions card is 'All' (NOT 'See all', unlike admin dashboard's flags card).",
    "All copy strings in this contract are authoritative; do not paraphrase."
  ]
}
