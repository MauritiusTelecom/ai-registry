{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "provider.keys",
  "description": "Telemetry events emitted by the Provider portal /keys route. CRITICAL: no event payload may contain the full secret — only the key id, prefix, last4.",
  "events": [
    {
      "name": "provider.keys.viewed",
      "trigger": "ProvKeys component mount.",
      "payload": {
        "type": "object",
        "required": ["totalCount"],
        "properties": {
          "totalCount":   { "type": "integer" },
          "activeCount":  { "type": "integer", "description": "count(NOT revoked)" },
          "revokedCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "provider.keys.action.create_key.clicked",
      "trigger": "User clicks 'Create key' header primary button."
    },
    {
      "name": "provider.keys.key.created",
      "trigger": "POST /provider/keys (201) succeeds.",
      "payload": {
        "type": "object",
        "required": ["keyId", "name", "scope"],
        "properties": {
          "keyId":  { "type": "string" },
          "name":   { "type": "string" },
          "scope":  { "type": "string" },
          "prefix": { "enum": ["air_pk_live_", "air_pk_test_"] }
        }
      }
    },
    {
      "name": "provider.keys.key.copied",
      "trigger": "User clicks 'Copy to clipboard' in the create-key modal AFTER the secret is shown.",
      "payload": {
        "type": "object",
        "required": ["keyId"],
        "properties": { "keyId": { "type": "string" } }
      }
    },
    {
      "name": "provider.keys.key.rotated",
      "trigger": "POST /provider/keys/{id}/rotate (200) succeeds.",
      "payload": {
        "type": "object",
        "required": ["keyId"],
        "properties": {
          "keyId":            { "type": "string" },
          "gracePeriodHours": { "type": "integer", "minimum": 0 }
        }
      }
    },
    {
      "name": "provider.keys.key.revoked",
      "trigger": "POST /provider/keys/{id}/revoke (200) succeeds.",
      "payload": {
        "type": "object",
        "required": ["keyId"],
        "properties": { "keyId": { "type": "string" } }
      }
    },
    {
      "name": "provider.keys.list.fetched",
      "trigger": "GET /provider/keys completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "provider.keys.error",
      "trigger": "Any of the keys endpoints returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ],
  "secret_handling_invariants": [
    "No event MAY include the full secret string.",
    "Telemetry MUST capture only keyId, name (operator-chosen, non-secret), scope token, and prefix/last4.",
    "The 'provider.keys.key.copied' event fires ONLY in the create-modal context where the secret was already revealed; it does NOT carry the secret."
  ]
}
