{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "provider.keys",
  "description": "Explicit UI contract for the Provider portal /keys route.",

  "route": {
    "portal": "provider",
    "path": "/keys",
    "html_entry": "portals/provider.html"
  },

  "shell_overrides": {
    "currentTitle": "API keys",
    "breadcrumb": ["Provider", "Org", "Keys"],
    "active_sidebar_item": "keys"
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title": "API keys",
      "subtitle": "Keys for publishing and CI.",
      "actions": [
        { "kind": "Btn", "variant": "primary", "icon": "plus", "label": "Create key", "test_id": "provider.keys.action.create_key" }
      ]
    },

    "data_table": {
      "component": "DataTable",
      "row_click_bound": false,
      "columns": [
        { "key": "name",     "label": "Name",                    "cell": { "kind": "text", "class": "p-cell-strong", "binding": "name" } },
        { "key": "key",      "label": "Key",
          "cell": {
            "kind": "text",
            "class": "p-mono-val",
            "template": "${prefix}…${last4}",
            "comment": "Composes prefix + Unicode horizontal ellipsis (U+2026) + last4. Full secret NEVER appears here."
          }
        },
        { "key": "scope",    "label": "Scope",                   "cell": { "kind": "text", "class": "p-mono-key", "binding": "scope" } },
        { "key": "created",  "label": "Created",   "width": 120, "cell": { "kind": "text", "class": "p-mono-key", "binding": "created" } },
        { "key": "lastUsed", "label": "Last used", "width": 120, "cell": { "kind": "text", "class": "p-mono-key", "binding": "lastUsed" } }
      ]
    }
  },

  "icons_used": ["plus"],

  "interactions": [
    { "id": "create_key", "trigger_test_id": "provider.keys.action.create_key", "effect": "open_create_key_modal_then_secret_reveal" }
  ],

  "create_key_modal": {
    "stages": ["form", "secret_reveal"],
    "form_fields": [
      { "label": "Name",  "kind": "input", "binding": "form.name",  "placeholder": "production" },
      { "label": "Scope", "kind": "multi-select", "binding": "form.scope", "default_value": ["publish:read", "publish:write"] },
      { "label": "Expires (optional)", "kind": "date", "binding": "form.expires" }
    ],
    "secret_reveal": {
      "code_block_class": "p-mono-block",
      "copy_button_label": "Copy to clipboard",
      "warning_banner_class": "p-banner-warn",
      "warning_text": "Save this now — you will not see it again.",
      "primary_button_label": "Done",
      "zeroise_on_close": true
    }
  },

  "empty_states": {
    "no_rows": { "body_text": "No API keys yet. Create one for production.", "cta_label": "Create key" }
  },

  "non_negotiables": [
    "Header has only ONE action button (primary 'Create key').",
    "No StatCards and no FilterBar on this page in v0.4.",
    "Key cell template uses Unicode horizontal ellipsis U+2026, NOT three dots.",
    "Full secret string MUST NEVER appear on this list page or in any list endpoint response.",
    "Full secret is shown ONCE inside the create-key modal and zeroised on close.",
    "Telemetry events MUST NOT include the full secret — only keyId, name, scope, prefix, last4.",
    "DataTable rows are non-interactive in v0.4 — do NOT bind onRowClick.",
    "`Create key` button must be disabled (with tooltip) for non-owner provider seats."
  ]
}
