{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "provider.analytics",
  "description": "Explicit UI contract for the Provider portal /analytics route.",

  "route": {
    "portal": "provider",
    "path": "/analytics",
    "html_entry": "portals/provider.html"
  },

  "shell_overrides": {
    "currentTitle": "Analytics",
    "breadcrumb": ["Provider", "Observe", "Analytics"],
    "active_sidebar_item": "analytics"
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title": "Analytics",
      "subtitle": "Traffic, latency and error rates across your resources.",
      "actions": []
    },

    "stat_grid": {
      "container_class": "p-grid p-grid-3",
      "container_style": { "marginBottom": 20 },
      "cards": [
        { "label": "Calls (30d)",  "value_binding": "summary.calls30d",   "delta_binding": "summary.calls30dDelta",   "deltaTone": "pos", "icon": "activity", "test_id": "provider.analytics.stat.calls30d" },
        { "label": "p95 latency",  "value_binding": "summary.p95Latency", "delta_binding": "summary.p95LatencyDelta", "deltaTone": "pos", "icon": "pulse",    "test_id": "provider.analytics.stat.p95Latency" },
        { "label": "Error rate",   "value_binding": "summary.errorRate",  "delta_binding": "summary.errorRateDelta",  "deltaTone": "neu", "icon": "zap",      "test_id": "provider.analytics.stat.errorRate" }
      ],
      "tone_rules": {
        "calls30d":   { "positive_delta": "pos", "negative_delta": "neg" },
        "p95Latency": { "negative_delta": "pos", "positive_delta": "neg", "comment": "Lower latency is better — sign is INVERTED for tone." },
        "errorRate":  { "zero_delta": "neu", "negative_delta": "pos", "positive_delta": "neg" }
      }
    },

    "chart_card": {
      "component": "p-card",
      "head": {
        "title": "Daily traffic",
        "sub": null,
        "right": null
      },
      "body": {
        "component": "UsageChart",
        "viewBox": "0 0 720 220",
        "padding": 26,
        "y_max": 2500,
        "grid_lines": 5,
        "grid_stroke": "var(--p-border)",
        "grid_stroke_width": 0.8,
        "grid_dash": "2 4",
        "bar_corner_radius": 2,
        "bar_order": ["mcp", "tool", "agent"],
        "agent_height_multiplier": 6,
        "day_label": {
          "font_family": "IBM Plex Mono",
          "font_size":   10,
          "fill":        "var(--p-text-3)"
        }
      }
    }
  },

  "icons_used": ["activity", "pulse", "zap"],

  "interactions": [],

  "empty_states": {
    "no_traffic": { "body_text": "No traffic in this window. Publish a resource to start seeing usage." }
  },

  "non_negotiables": [
    "PageHeader has NO action buttons.",
    "StatCard order is fixed: Calls (30d) → p95 latency → Error rate.",
    "StatCards on this page DO NOT carry a 'sub' line (unlike the dashboard's StatCards).",
    "p95 latency tone INVERTS the delta sign: smaller latency = positive tone.",
    "Daily traffic card has NO sub line and NO legend in v0.4 — chart only.",
    "Chart geometry is identical to the dashboard's Weekly traffic card (same UsageChart component).",
    "Window is 30d in production; v0.4 prototype reuses the 7-day mock for visual continuity.",
    "Page is fully read-only — no writes anywhere."
  ]
}
