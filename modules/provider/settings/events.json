{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "provider.settings",
  "description": "Telemetry events emitted by the Provider portal /settings route.",
  "events": [
    {
      "name": "provider.settings.viewed",
      "trigger": "ProvSettings component mount."
    },
    {
      "name": "provider.settings.field.changed",
      "trigger": "Any field's value changes (debounce 250ms in production).",
      "payload": {
        "type": "object",
        "required": ["card", "field"],
        "properties": {
          "card":  { "enum": ["organisation", "notifications"] },
          "field": { "type": "string" }
        }
      }
    },
    {
      "name": "provider.settings.organisation.saved",
      "trigger": "PATCH /provider/settings/organisation (200) succeeds.",
      "payload": {
        "type": "object",
        "required": ["fields"],
        "properties": {
          "fields": {
            "type": "array",
            "items": { "enum": ["displayName", "domain", "publicBio"] }
          }
        }
      }
    },
    {
      "name": "provider.settings.notifications.saved",
      "trigger": "PATCH /provider/settings/notifications (200) succeeds.",
      "payload": {
        "type": "object",
        "required": ["fields"],
        "properties": {
          "fields": {
            "type": "array",
            "items": { "enum": ["incidentChannel", "onCallEmail", "webhook"] }
          }
        }
      }
    },
    {
      "name": "provider.settings.domain.verification_started",
      "trigger": "POST /provider/settings/domain-verify accepts a new domain challenge (201).",
      "payload": {
        "type": "object",
        "required": ["newDomain", "proofChannel"],
        "properties": {
          "newDomain":    { "type": "string" },
          "proofChannel": { "enum": ["dns-txt", "signed-manifest", "https-callback"] }
        }
      }
    },
    {
      "name": "provider.settings.fetched",
      "trigger": "GET /provider/settings completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms"],
        "properties": {
          "status": { "type": "integer" },
          "ms":     { "type": "integer", "minimum": 0 }
        }
      }
    },
    {
      "name": "provider.settings.error",
      "trigger": "Any settings endpoint returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
