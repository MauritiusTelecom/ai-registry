{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "provider.settings",
  "description": "Explicit UI contract for the Provider portal /settings route.",

  "route": {
    "portal": "provider",
    "path": "/settings",
    "html_entry": "portals/provider.html"
  },

  "shell_overrides": {
    "currentTitle": "Settings",
    "breadcrumb": ["Provider", "Settings"],
    "active_sidebar_item": "settings"
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title": "Provider settings",
      "subtitle": null,
      "actions": []
    },

    "card_grid": {
      "container_class": "p-grid p-grid-2",
      "cards": [
        {
          "id": "organisation",
          "title": "Organisation",
          "title_class": "p-card-title",
          "title_style": { "marginBottom": 14 },
          "fields": [
            { "label": "Display name", "kind": "input",    "binding": "organisation.displayName", "default_value": "eduMu",                                                                                  "test_id": "provider.settings.organisation.displayName" },
            { "label": "Domain",       "kind": "input",    "binding": "organisation.domain",      "default_value": "edu.gov.mu",                                                                             "test_id": "provider.settings.organisation.domain" },
            { "label": "Public bio",   "kind": "textarea", "binding": "organisation.publicBio",   "default_value": "Mauritius Ministry of Education — open educational resources, retrieval-only.",          "test_id": "provider.settings.organisation.publicBio" }
          ]
        },
        {
          "id": "notifications",
          "title": "Notifications",
          "title_class": "p-card-title",
          "title_style": { "marginBottom": 14 },
          "fields": [
            { "label": "Incident channel", "kind": "input", "binding": "notifications.incidentChannel", "default_value": "#edu-air-ops (Slack)", "test_id": "provider.settings.notifications.incidentChannel" },
            { "label": "On-call email",    "kind": "input", "binding": "notifications.onCallEmail",     "default_value": "oncall@edu.gov.mu",   "test_id": "provider.settings.notifications.onCallEmail" },
            { "label": "Webhook",          "kind": "input", "binding": "notifications.webhook",         "placeholder":   "https://...",         "test_id": "provider.settings.notifications.webhook" }
          ]
        }
      ]
    }
  },

  "icons_used": [],

  "save_pattern": {
    "default": "implicit_save_on_blur",
    "alternative": "sticky_footer_with_save_changes_button",
    "debounce_ms": 250,
    "endpoints": {
      "organisation":  "PATCH /provider/settings/organisation",
      "notifications": "PATCH /provider/settings/notifications"
    }
  },

  "non_negotiables": [
    "Page uses a 2-column card grid (p-grid p-grid-2). Card order is fixed: Organisation → Notifications.",
    "PageHeader has NO subtitle and NO action buttons.",
    "Each field is rendered via the p-field wrapper (label + input/textarea side-by-side).",
    "Default values must match exactly: 'eduMu', 'edu.gov.mu', 'Mauritius Ministry of Education — open educational resources, retrieval-only.', '#edu-air-ops (Slack)', 'oncall@edu.gov.mu'.",
    "Em dash (U+2014) in the public bio default MUST be preserved.",
    "Webhook field has placeholder 'https://...' and NO default value.",
    "Domain field is read-only post-onboarding in production; changing it requires the re-verification flow.",
    "Webhook secret is shown ONCE in a modal on save (same flow as /keys); zeroise on close."
  ]
}
