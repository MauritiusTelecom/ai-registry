{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "provider.resources",
  "description": "Telemetry events emitted by the Provider portal /resources route.",
  "events": [
    {
      "name": "provider.resources.viewed",
      "trigger": "ProvResources component mount.",
      "payload": {
        "type": "object",
        "required": ["totalCount"],
        "properties": {
          "totalCount":      { "type": "integer" },
          "draftCount":      { "type": "integer" },
          "experimentalCount": { "type": "integer" },
          "verifiedCount":   { "type": "integer" }
        }
      }
    },
    {
      "name": "provider.resources.action.publish_resource.clicked",
      "trigger": "User clicks the 'Publish resource' header primary button.",
      "side_effects": ["navigate(#/publish)"]
    },
    {
      "name": "provider.resources.row.viewed",
      "trigger": "Each row in the DataTable is rendered.",
      "payload": {
        "type": "object",
        "required": ["resourceId", "kind", "status"],
        "properties": {
          "resourceId": { "type": "string" },
          "kind":       { "enum": ["mcp-server", "agent", "tool", "model"] },
          "status":     { "type": "string" }
        }
      }
    },
    {
      "name": "provider.resources.list.fetched",
      "trigger": "GET /provider/resources completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "provider.resources.error",
      "trigger": "Any of the resources endpoints returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
