{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "provider.resources",
  "description": "Explicit UI contract for the Provider portal /resources route.",

  "route": {
    "portal": "provider",
    "path": "/resources",
    "html_entry": "portals/provider.html"
  },

  "shell_overrides": {
    "currentTitle": "My resources",
    "breadcrumb": ["Provider", "Publishing", "Resources"],
    "active_sidebar_item": "resources"
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title": "My resources",
      "subtitle_template": "Resources you publish under ${providerName}.",
      "subtitle_default":  "Resources you publish under eduMu.",
      "actions": [
        { "kind": "Btn", "variant": "primary", "icon": "plus", "label": "Publish resource", "test_id": "provider.resources.action.publish_resource" }
      ]
    },

    "data_table": {
      "component": "DataTable",
      "row_click_bound": false,
      "row_click_handler_in_source": "() => {}",
      "columns": [
        {
          "key": "slug", "label": "Resource",
          "cell": {
            "kind": "stack",
            "class": "p-cell-stack",
            "lines": [
              { "binding": "slug",                  "class": "p-cell-strong" },
              { "template": "${kind} · ${version}", "class": "p-cell-meta" }
            ]
          }
        },
        { "key": "status",  "label": "Status",   "width": 130, "cell": { "kind": "renderer", "renderer": "StatusPill", "props": { "status": "row.status" } } },
        { "key": "sov",     "label": "Tier",     "width": 100, "cell": { "kind": "tag",  "class": "p-tag",      "binding": "sov" } },
        { "key": "usage",   "label": "7d calls", "width": 100, "cell": { "kind": "text", "class": "p-mono-val", "binding": "usage" } },
        { "key": "latency", "label": "p95",      "width": 90,  "cell": { "kind": "text", "class": "p-mono-val", "binding": "latency" } },
        { "key": "errors",  "label": "errors",   "width": 90,  "cell": { "kind": "text", "class": "p-mono-val", "binding": "errors" } },
        { "key": "updated", "label": "Updated",  "width": 110, "cell": { "kind": "text", "class": "p-mono-key", "binding": "updated" } }
      ]
    }
  },

  "icons_used": ["plus"],

  "status_pill_states_used": ["verified", "experimental", "draft", "review", "isolated", "archived"],

  "interactions": [
    { "id": "publish_resource", "trigger_test_id": "provider.resources.action.publish_resource", "effect": "navigate", "to": "/publish" }
  ],

  "empty_states": {
    "no_rows": { "body_text": "No resources yet. Publish your first one to get started.", "cta_label": "Publish resource", "cta_to": "/publish" }
  },

  "non_negotiables": [
    "Header has only ONE action button (primary 'Publish resource').",
    "No StatCards and no FilterBar on this page in v0.4.",
    "Column header 'errors' MUST stay lowercase to match the source.",
    "Column 'p95' is the latency column; do NOT relabel to 'Latency'.",
    "DataTable rows are non-interactive in v0.4 — onRowClick is bound to a no-op stub but must NOT trigger navigation or drawers.",
    "The em dash sentinel '—' (U+2014) is used in metric cells for draft / pre-launch resources.",
    "Resource cell stacks slug (strong) over '${kind} · ${version}' (meta).",
    "Performance metric cells (usage / latency / errors) MUST aggregate this provider's traffic only — never cross-provider."
  ]
}
