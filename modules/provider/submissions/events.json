{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "provider.submissions",
  "description": "Telemetry events emitted by the Provider portal /submissions route.",
  "events": [
    {
      "name": "provider.submissions.viewed",
      "trigger": "ProvSubmissions component mount.",
      "payload": {
        "type": "object",
        "required": ["totalCount"],
        "properties": {
          "totalCount":   { "type": "integer" },
          "openCount":    { "type": "integer", "description": "count(status IN ('pending','review'))" }
        }
      }
    },
    {
      "name": "provider.submissions.row.viewed",
      "trigger": "Each submission row is rendered.",
      "payload": {
        "type": "object",
        "required": ["submissionId", "stage", "status"],
        "properties": {
          "submissionId": { "type": "string" },
          "stage":        { "enum": ["sovereignty", "evaluation", "safety"] },
          "status":       { "type": "string" }
        }
      }
    },
    {
      "name": "provider.submissions.list.fetched",
      "trigger": "GET /provider/submissions completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "provider.submissions.submission.withdrawn",
      "trigger": "POST /provider/submissions/{id}/withdraw succeeds (production-only).",
      "payload": {
        "type": "object",
        "required": ["submissionId"],
        "properties": { "submissionId": { "type": "string" } }
      }
    },
    {
      "name": "provider.submissions.error",
      "trigger": "Any of the submissions endpoints returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
