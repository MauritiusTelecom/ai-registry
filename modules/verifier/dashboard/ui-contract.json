{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "verifier.dashboard",
  "description": "Explicit UI contract for the Verifier portal dashboard route.",

  "route": {
    "portal": "verifier",
    "path": "/",
    "html_entry": "portals/verifier.html",
    "default_path_when_hash_empty": "/"
  },

  "design_tokens_inherited_from": "modules/admin/dashboard/ui-contract.json",

  "shell": {
    "component": "PortalShell",
    "props": {
      "role": "verifier",
      "portalLabel": "Verifier",
      "portalIcon": "check",
      "currentTitle": "Dashboard",
      "breadcrumb": ["Verifier", "Dashboard"]
    },
    "sidebar": {
      "logo_text": "AI Registry",
      "logo_sub_label": "Verifier",
      "logo_sub_icon": "check",
      "items": [
        { "id": "home",       "label": "Dashboard",     "icon": "home",     "path": "/" },
        { "divider": true, "id": "div_q", "label": "Queue" },
        { "id": "queue",      "label": "Open reviews",  "icon": "inbox",    "path": "/queue", "badge": "5" },
        { "id": "decided",    "label": "Decided",       "icon": "audit",    "path": "/decided" },
        { "divider": true, "id": "div_e", "label": "Evaluation" },
        { "id": "bench",      "label": "Benchmarks",    "icon": "database", "path": "/benchmarks" },
        { "id": "runs",       "label": "Eval runs",     "icon": "activity", "path": "/runs" },
        { "id": "redteam",    "label": "Red-team",      "icon": "flag",     "path": "/redteam", "badge": "2" },
        { "divider": true, "id": "div_o", "label": "Output" },
        { "id": "reports",    "label": "Reports",       "icon": "doc",      "path": "/reports" },
        { "id": "settings",   "label": "Settings",      "icon": "settings", "path": "/settings" }
      ]
    }
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title": "Verifier desk",
      "subtitle": "Independent sovereignty, evaluation and safety review for the registry.",
      "actions": [
        { "kind": "Btn", "variant": "primary", "icon": "check", "label": "Open next in queue", "test_id": "verifier.dashboard.action.open_next" }
      ]
    },

    "stat_grid": {
      "container_class": "p-grid p-grid-4",
      "container_style": { "marginBottom": 20 },
      "cards": [
        { "label": "Open reviews",  "value_binding": "summary.openReviews", "delta": "+2",   "deltaTone": "neg", "sub": "awaiting",       "icon": "check",    "test_id": "verifier.dashboard.stat.openReviews" },
        { "label": "Decided (30d)", "value": "42",                          "delta": "+6",   "deltaTone": "pos", "sub": "closed",         "icon": "audit",    "test_id": "verifier.dashboard.stat.decided30d" },
        { "label": "Pass rate",     "value": "74%",                         "delta": "-3pp", "deltaTone": "neg", "sub": "rolling 30d",    "icon": "activity", "test_id": "verifier.dashboard.stat.passRate" },
        { "label": "Open red-team", "value_binding": "summary.openRedteam", "delta": "0",    "deltaTone": "neu", "sub": "findings",       "icon": "flag",     "test_id": "verifier.dashboard.stat.openRedteam" }
      ],
      "tone_rules": {
        "openReviews": { "positive_delta": "neg", "comment": "More backlog is bad." },
        "passRate":    { "negative_delta": "neg" }
      }
    },

    "split_row": {
      "container_class": "p-grid p-grid-2",
      "container_style": { "gridTemplateColumns": "2fr 1fr" },
      "left_card": {
        "component": "p-card",
        "head": {
          "title": "Top of queue",
          "sub": "SLA breach in red",
          "right_link": { "label": "See all", "href": "#/queue", "class": "p-link", "test_id": "verifier.dashboard.queue.see_all" }
        },
        "body": {
          "component": "DataTable",
          "row_click_bound": false,
          "rows_binding": "V.queue.slice(0, 4)",
          "columns": [
            { "key": "id",     "label": "ID",     "width": 100, "cell": { "kind": "text", "class": "p-mono-val",   "binding": "id" } },
            { "key": "target", "label": "Target",                "cell": { "kind": "text", "class": "p-cell-strong", "binding": "target" } },
            { "key": "stage",  "label": "Stage",  "width": 130, "cell": { "kind": "tag",  "class": "p-tag",         "binding": "stage" } },
            { "key": "age",    "label": "Age",    "width": 80,
              "cell": {
                "kind": "text",
                "class": "p-mono-val",
                "color_when": {
                  "match": "row.age.endsWith('d') && parseInt(row.age) > 4",
                  "true":  "#ef4444",
                  "false": "var(--p-text)"
                },
                "binding": "age"
              }
            }
          ]
        }
      },
      "right_card": {
        "component": "p-card",
        "head": { "title": "Active red-team" },
        "body": {
          "kind": "list",
          "filter": "status !== 'resolved'",
          "row_template": {
            "container_class": "p-row",
            "container_style": { "justifyContent": "space-between", "padding": "8px 0", "borderBottom": "1px solid var(--p-border-soft)", "alignItems": "flex-start" },
            "left_stack": {
              "container_style": { "flex": 1, "minWidth": 0 },
              "lines": [
                { "binding": "target", "class": "p-cell-strong", "style": { "fontSize": 13 } },
                { "binding": "vector", "class": "p-cell-meta" }
              ]
            },
            "right_pill": {
              "kind": "pill",
              "pill_class_map": { "high": "p-pill p-pill-isolated", "med": "p-pill p-pill-pending", "low": "p-pill p-pill-pending" },
              "v04_fallback": "p-pill p-pill-pending",
              "pill_dot_class": "p-pill-dot",
              "binding": "severity"
            }
          }
        }
      }
    }
  },

  "icons_used": ["home", "inbox", "audit", "database", "activity", "flag", "doc", "settings", "check"],

  "interactions": [
    { "id": "open_next",  "trigger_test_id": "verifier.dashboard.action.open_next", "effect": "navigate('/queue') and select first row" },
    { "id": "queue_all",  "trigger_test_id": "verifier.dashboard.queue.see_all",    "effect": "navigate('/queue')" }
  ],

  "non_negotiables": [
    "Header has only ONE primary action: 'Open next in queue' with check icon.",
    "StatCard order is fixed: Open reviews → Decided (30d) → Pass rate → Open red-team.",
    "Pass rate delta uses 'pp' (percentage-points) suffix, NOT '%'.",
    "Split row uses gridTemplateColumns '2fr 1fr'.",
    "Queue Age cell colour-codes red (#ef4444) when age ends with 'd' AND parseInt(age) > 4. Threshold is STRICTLY GREATER THAN 4.",
    "Top of queue uses V.queue.slice(0, 4) — exactly 4 rows.",
    "Active red-team filter is `status !== 'resolved'` — both 'open' and 'review' rows surface.",
    "Active red-team severity pill: high → p-pill-isolated, otherwise → p-pill-pending. v0.4 has no `p-pill-draft` for severity 'low' on this page.",
    "Active red-team row uses alignItems: 'flex-start' so the pill aligns with the first text line.",
    "Sidebar has TWO badges: queue (5) and redteam (2)."
  ]
}
