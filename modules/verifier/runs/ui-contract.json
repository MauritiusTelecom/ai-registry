{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "verifier.runs",
  "description": "Explicit UI contract for the Verifier portal /runs route.",

  "route": {
    "portal": "verifier",
    "path": "/runs",
    "html_entry": "portals/verifier.html"
  },

  "shell_overrides": {
    "currentTitle": "Eval runs",
    "breadcrumb": ["Verifier", "Evaluation", "Runs"],
    "active_sidebar_item": "runs"
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title": "Eval runs",
      "subtitle": "Latest benchmark runs and their outcomes.",
      "actions": []
    },

    "data_table": {
      "component": "DataTable",
      "row_click_bound": false,
      "columns": [
        { "key": "id",       "label": "Run",        "width": 110, "cell": { "kind": "text", "class": "p-mono-val", "binding": "id" } },
        { "key": "target",   "label": "Target",                  "cell": { "kind": "text", "class": "p-cell-strong", "binding": "target" } },
        { "key": "bench",    "label": "Benchmark",               "cell": { "kind": "text", "class": "p-mono-val", "binding": "bench" } },
        { "key": "score",    "label": "Score",     "width": 100, "cell": { "kind": "text", "class": "p-mono-val", "format": "toFixed(2)", "binding": "score" } },
        { "key": "baseline", "label": "Baseline",  "width": 100, "cell": { "kind": "text", "class": "p-mono-key", "format": "toFixed(2)", "binding": "baseline" } },
        { "key": "status",   "label": "Status",    "width": 100,
          "cell": {
            "kind": "renderer",
            "renderer": "StatusPill",
            "props": { "status": "row.status === 'pass' ? 'verified' : 'failed'" }
          }
        },
        { "key": "ran",      "label": "Ran",       "width": 160, "cell": { "kind": "text", "class": "p-mono-key", "binding": "ran" } }
      ]
    }
  },

  "icons_used": [],

  "status_pill_states_used": ["verified", "failed"],

  "interactions": [],

  "empty_states": {
    "no_rows": { "body_text": "No eval runs yet. Trigger one from /benchmarks." }
  },

  "non_negotiables": [
    "PageHeader has NO action buttons.",
    "DataTable column order is fixed: Run → Target → Benchmark → Score → Baseline → Status → Ran.",
    "Score and Baseline cells use toFixed(2) — always two decimals (0.5 → '0.50', 0.74 → '0.74').",
    "Score uses p-mono-val (primary), Baseline uses p-mono-key (muted) to visually distinguish them.",
    "Status maps the persisted enum (pass / fail) to StatusPill: pass → verified, fail → failed.",
    "Ran timestamp width is 160 (room for 'YYYY-MM-DD HH:MM').",
    "DataTable rows are non-interactive in v0.4 — do NOT bind onRowClick.",
    "Runs are IMMUTABLE once completed — no edit affordances under any role."
  ]
}
