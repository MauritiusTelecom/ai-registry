{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "verifier.runs",
  "description": "Telemetry events emitted by the Verifier portal /runs route.",
  "events": [
    {
      "name": "verifier.runs.viewed",
      "trigger": "VerRuns component mount.",
      "payload": {
        "type": "object",
        "required": ["totalCount", "passCount", "failCount"],
        "properties": {
          "totalCount": { "type": "integer" },
          "passCount":  { "type": "integer" },
          "failCount":  { "type": "integer" }
        }
      }
    },
    {
      "name": "verifier.runs.row.viewed",
      "trigger": "Each run row renders.",
      "payload": {
        "type": "object",
        "required": ["runId", "status"],
        "properties": {
          "runId":  { "type": "string" },
          "status": { "enum": ["pass", "fail"] }
        }
      }
    },
    {
      "name": "verifier.runs.list.fetched",
      "trigger": "GET /verifier/runs completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "verifier.runs.row.opened",
      "trigger": "Production-only: user clicks a row to open the per-item drawer.",
      "payload": {
        "type": "object",
        "required": ["runId"],
        "properties": { "runId": { "type": "string" } }
      }
    },
    {
      "name": "verifier.runs.error",
      "trigger": "GET /verifier/runs returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status":  { "type": "integer" },
          "problem": { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
