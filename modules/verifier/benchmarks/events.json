{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "verifier.benchmarks",
  "description": "Telemetry events emitted by the Verifier portal /benchmarks route.",
  "events": [
    {
      "name": "verifier.benchmarks.viewed",
      "trigger": "VerBenchmarks component mount.",
      "payload": {
        "type": "object",
        "required": ["totalCount", "evalCount", "safetyCount"],
        "properties": {
          "totalCount":  { "type": "integer" },
          "evalCount":   { "type": "integer" },
          "safetyCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "verifier.benchmarks.action.new_benchmark.clicked",
      "trigger": "User clicks 'New benchmark' header primary button."
    },
    {
      "name": "verifier.benchmarks.card.inspect.clicked",
      "trigger": "User clicks 'Inspect' secondary button on a benchmark card.",
      "payload": {
        "type": "object",
        "required": ["benchmarkId"],
        "properties": { "benchmarkId": { "type": "string" } }
      }
    },
    {
      "name": "verifier.benchmarks.card.run.clicked",
      "trigger": "User clicks 'Run' ghost button on a benchmark card.",
      "payload": {
        "type": "object",
        "required": ["benchmarkId"],
        "properties": { "benchmarkId": { "type": "string" } }
      }
    },
    {
      "name": "verifier.benchmarks.run.started",
      "trigger": "POST /verifier/benchmarks/{id}/runs returns 202.",
      "payload": {
        "type": "object",
        "required": ["benchmarkId", "target", "runId"],
        "properties": {
          "benchmarkId": { "type": "string" },
          "target":      { "type": "string" },
          "runId":       { "type": "string" }
        }
      }
    },
    {
      "name": "verifier.benchmarks.list.fetched",
      "trigger": "GET /verifier/benchmarks completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "verifier.benchmarks.error",
      "trigger": "Any of the benchmarks endpoints returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
