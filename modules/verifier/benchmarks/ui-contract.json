{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "verifier.benchmarks",
  "description": "Explicit UI contract for the Verifier portal /benchmarks route.",

  "route": {
    "portal": "verifier",
    "path": "/benchmarks",
    "html_entry": "portals/verifier.html"
  },

  "shell_overrides": {
    "currentTitle": "Benchmarks",
    "breadcrumb": ["Verifier", "Evaluation", "Benchmarks"],
    "active_sidebar_item": "bench"
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title": "Benchmarks",
      "subtitle": "Evaluation suites maintained by the verifier collegium.",
      "actions": [
        { "kind": "Btn", "variant": "primary", "icon": "plus", "label": "New benchmark", "test_id": "verifier.benchmarks.action.new_benchmark" }
      ]
    },

    "card_grid": {
      "container_class": "p-grid p-grid-2",
      "card_template": {
        "component": "p-card",
        "head": {
          "left": {
            "kind": "stack",
            "lines": [
              { "binding": "name",                  "class": "p-card-title" },
              { "template": "${kind} · ${version}", "class": "p-card-sub" }
            ]
          },
          "right": {
            "kind": "tag",
            "class": "p-tag",
            "template": "${items} items"
          }
        },
        "updated_row": {
          "container_class": "p-row",
          "container_style": { "justifyContent": "space-between", "marginTop": 4 },
          "left":  { "kind": "text", "class": "p-mono-key", "text": "updated" },
          "right": { "kind": "text", "class": "p-mono-val", "binding": "updated" }
        },
        "divider_class": "p-divider",
        "actions_row": {
          "container_class": "p-row",
          "container_style": { "gap": 8 },
          "items": [
            { "kind": "Btn", "variant": "secondary", "size": "sm", "icon": "eye", "label": "Inspect", "test_id": "verifier.benchmarks.card.inspect" },
            { "kind": "Btn", "variant": "ghost",     "size": "sm", "icon": "zap", "label": "Run",     "test_id": "verifier.benchmarks.card.run" }
          ]
        }
      }
    }
  },

  "icons_used": ["plus", "eye", "zap"],

  "interactions": [
    { "id": "new_benchmark", "trigger_test_id": "verifier.benchmarks.action.new_benchmark", "effect": "open_create_benchmark_modal" },
    { "id": "card_inspect",  "trigger_test_id": "verifier.benchmarks.card.inspect",         "effect": "navigate_to_detail" },
    { "id": "card_run",      "trigger_test_id": "verifier.benchmarks.card.run",             "effect": "open_run_modal_then_POST_runs" }
  ],

  "empty_states": {
    "no_rows": { "single_full_width_card": true, "body_text": "No benchmarks yet. Author the first." }
  },

  "non_negotiables": [
    "Header has only ONE primary action: 'New benchmark' with plus icon.",
    "Page uses a 2-column card grid (p-grid p-grid-2).",
    "Each card has exactly: head (name + '${kind} · ${version}' sub on left, '${items} items' p-tag chip on right) → updated row (mono key 'updated' + mono value) → divider → action row (Inspect secondary sm + Run ghost sm).",
    "Action buttons are size='sm' — do NOT eyeball-shrink.",
    "Items chip uses the literal suffix ' items' (with leading space).",
    "Card sub uses Unicode middle dot U+00B7 between kind and version.",
    "Kind taxonomy in v0.4: 'evaluation', 'safety'."
  ]
}
