{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "verifier.redteam",
  "description": "Explicit UI contract for the Verifier portal /redteam route.",

  "route": {
    "portal": "verifier",
    "path": "/redteam",
    "html_entry": "portals/verifier.html"
  },

  "shell_overrides": {
    "currentTitle": "Red-team",
    "breadcrumb": ["Verifier", "Evaluation", "Red-team"],
    "active_sidebar_item": "redteam",
    "sidebar_badge": "2"
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title": "Red-team findings",
      "subtitle": "Adversarial probes against registry resources.",
      "actions": [
        { "kind": "Btn", "variant": "primary", "icon": "plus", "label": "New finding", "test_id": "verifier.redteam.action.new_finding" }
      ]
    },

    "data_table": {
      "component": "DataTable",
      "row_click_bound": false,
      "columns": [
        { "key": "id",       "label": "ID",       "width": 100, "cell": { "kind": "text", "class": "p-mono-val",   "binding": "id" } },
        { "key": "target",   "label": "Target",                 "cell": { "kind": "text", "class": "p-cell-strong", "binding": "target" } },
        { "key": "vector",   "label": "Vector",                 "cell": { "kind": "text", "style": { "color": "var(--p-text-2)" }, "binding": "vector" } },
        { "key": "severity", "label": "Severity", "width": 110,
          "cell": {
            "kind": "pill",
            "v04_pill_class_map":          { "high": "p-pill p-pill-isolated", "med": "p-pill p-pill-pending", "low": "p-pill p-pill-pending" },
            "production_pill_class_map":   { "high": "p-pill p-pill-isolated", "med": "p-pill p-pill-pending", "low": "p-pill p-pill-draft" },
            "pill_dot_class": "p-pill-dot",
            "binding": "severity"
          }
        },
        { "key": "opened",   "label": "Opened",   "width": 110, "cell": { "kind": "text", "class": "p-mono-key", "binding": "opened" } },
        { "key": "status",   "label": "Status",   "width": 110,
          "cell": {
            "kind": "renderer",
            "renderer": "StatusPill",
            "props": { "status": "row.status === 'open' ? 'pending' : row.status === 'review' ? 'review' : 'verified'" }
          }
        }
      ]
    }
  },

  "icons_used": ["plus"],

  "status_pill_states_used": ["pending", "review", "verified"],

  "interactions": [
    { "id": "new_finding", "trigger_test_id": "verifier.redteam.action.new_finding", "effect": "open_create_finding_modal" }
  ],

  "empty_states": {
    "no_rows": { "body_text": "No red-team findings. Healthy posture." }
  },

  "non_negotiables": [
    "Header has only ONE primary action: 'New finding' with plus icon.",
    "DataTable column order is fixed: ID → Target → Vector → Severity → Opened → Status.",
    "Vector column uses muted text style (var(--p-text-2)).",
    "Severity v0.4 source maps high → p-pill-isolated, anything else → p-pill-pending. Production should add low → p-pill-draft.",
    "Status maps the persisted enum (open / review / resolved) to StatusPill: open → pending, review → review, resolved → verified.",
    "DataTable rows are non-interactive in v0.4 — do NOT bind onRowClick.",
    "Sidebar badge value comes from openCount in the list endpoint."
  ]
}
