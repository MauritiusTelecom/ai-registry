{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "verifier.queue",
  "description": "Telemetry events emitted by the Verifier portal /queue route.",
  "events": [
    {
      "name": "verifier.queue.viewed",
      "trigger": "VerQueue component mount.",
      "payload": {
        "type": "object",
        "required": ["totalCount"],
        "properties": {
          "totalCount":     { "type": "integer" },
          "highPriority":   { "type": "integer" },
          "slaBreached":    { "type": "integer" }
        }
      }
    },
    {
      "name": "verifier.queue.row.viewed",
      "trigger": "Each queue row renders.",
      "payload": {
        "type": "object",
        "required": ["reviewId", "stage", "priority"],
        "properties": {
          "reviewId": { "type": "string" },
          "stage":    { "enum": ["sovereignty", "evaluation", "safety"] },
          "priority": { "enum": ["high", "med", "low"] }
        }
      }
    },
    {
      "name": "verifier.queue.list.fetched",
      "trigger": "GET /verifier/queue completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "verifier.queue.row.opened",
      "trigger": "Production-only: user clicks a row to open the decision drawer.",
      "payload": {
        "type": "object",
        "required": ["reviewId"],
        "properties": { "reviewId": { "type": "string" } }
      }
    },
    {
      "name": "verifier.queue.review.decided",
      "trigger": "POST /verifier/queue/{id}/decision succeeds (production-only).",
      "payload": {
        "type": "object",
        "required": ["reviewId", "decision", "auditId"],
        "properties": {
          "reviewId": { "type": "string" },
          "decision": { "enum": ["approve", "reject", "withdraw"] },
          "auditId":  { "type": "string" }
        }
      }
    },
    {
      "name": "verifier.queue.error",
      "trigger": "Any of the queue endpoints returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
