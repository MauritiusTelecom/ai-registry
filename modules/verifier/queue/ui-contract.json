{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "verifier.queue",
  "description": "Explicit UI contract for the Verifier portal /queue route.",

  "route": {
    "portal": "verifier",
    "path": "/queue",
    "html_entry": "portals/verifier.html"
  },

  "shell_overrides": {
    "currentTitle": "Review queue",
    "breadcrumb": ["Verifier", "Queue", "Open"],
    "active_sidebar_item": "queue",
    "sidebar_badge": "5"
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title": "Review queue",
      "subtitle": "Submissions awaiting your decision.",
      "actions": []
    },

    "data_table": {
      "component": "DataTable",
      "row_click_bound": true,
      "row_click_handler_in_source": "() => {}",
      "row_click_effect_in_production": "open_decision_drawer",
      "columns": [
        { "key": "id", "label": "ID", "width": 100, "cell": { "kind": "text", "class": "p-mono-val", "binding": "id" } },
        {
          "key": "target", "label": "Target",
          "cell": {
            "kind": "stack",
            "class": "p-cell-stack",
            "lines": [
              { "binding": "target",                  "class": "p-cell-strong" },
              { "template": "${kind} · ${provider}",   "class": "p-cell-meta" }
            ]
          }
        },
        { "key": "stage",    "label": "Stage",    "width": 130, "cell": { "kind": "tag", "class": "p-tag", "binding": "stage" } },
        { "key": "priority", "label": "Priority", "width": 100,
          "cell": {
            "kind": "pill",
            "pill_class_map": { "high": "p-pill p-pill-isolated", "med": "p-pill p-pill-pending", "low": "p-pill p-pill-draft" },
            "pill_dot_class": "p-pill-dot",
            "binding": "priority"
          }
        },
        { "key": "queued",   "label": "Queued",   "width": 110, "cell": { "kind": "text", "class": "p-mono-key", "binding": "queued" } },
        { "key": "age",      "label": "Age",      "width": 80,  "cell": { "kind": "text", "class": "p-mono-val", "binding": "age", "v04_no_sla_color": true } }
      ]
    }
  },

  "icons_used": [],

  "interactions": [
    { "id": "row_click_v04",       "trigger": "row.click", "effect": "no-op stub" },
    { "id": "row_click_production", "trigger": "row.click", "effect": "open_decision_drawer" }
  ],

  "empty_states": {
    "no_rows": { "body_text": "Queue is clear. Nothing to review." }
  },

  "non_negotiables": [
    "PageHeader has NO action buttons in v0.4.",
    "DataTable column order is fixed: ID → Target → Stage → Priority → Queued → Age.",
    "Target uses a stack: top = target slug (strong), bottom = '${kind} · ${provider}' (meta).",
    "Priority pill mapping: high → p-pill-isolated, med → p-pill-pending, low → p-pill-draft.",
    "Age cell on this page does NOT colour-code by SLA in v0.4 source (the dashboard preview does).",
    "DataTable passes onRowClick={() => {}} (no-op stub) — production replaces with the decision drawer trigger.",
    "Sidebar badge value comes from the live row count.",
    "The mcp/customs-tariff v2 row uses a single space between the slug and the SemVer suffix."
  ]
}
