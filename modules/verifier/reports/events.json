{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "verifier.reports",
  "description": "Telemetry events emitted by the Verifier portal /reports route.",
  "events": [
    {
      "name": "verifier.reports.viewed",
      "trigger": "VerReports component mount.",
      "payload": {
        "type": "object",
        "required": ["totalCount", "signedCount"],
        "properties": {
          "totalCount":  { "type": "integer" },
          "signedCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "verifier.reports.action.draft_report.clicked",
      "trigger": "User clicks 'Draft report' header primary button."
    },
    {
      "name": "verifier.reports.draft.created",
      "trigger": "POST /verifier/reports (201) succeeds.",
      "payload": {
        "type": "object",
        "required": ["reportId", "kind"],
        "properties": {
          "reportId": { "type": "string" },
          "kind":     { "enum": ["quarterly", "incident", "annual"] }
        }
      }
    },
    {
      "name": "verifier.reports.card.view.clicked",
      "trigger": "User clicks the 'View' secondary button on a report card.",
      "payload": {
        "type": "object",
        "required": ["reportId"],
        "properties": { "reportId": { "type": "string" } }
      }
    },
    {
      "name": "verifier.reports.card.download.clicked",
      "trigger": "User clicks the 'Download PDF' ghost button on a report card.",
      "payload": {
        "type": "object",
        "required": ["reportId"],
        "properties": { "reportId": { "type": "string" } }
      }
    },
    {
      "name": "verifier.reports.signed.viewed",
      "trigger": "Card renders with the green 'signed' p-tag visible.",
      "payload": {
        "type": "object",
        "required": ["reportId"],
        "properties": { "reportId": { "type": "string" } }
      }
    },
    {
      "name": "verifier.reports.report.signed",
      "trigger": "POST /verifier/reports/{id}/sign succeeds (production-only).",
      "payload": {
        "type": "object",
        "required": ["reportId"],
        "properties": { "reportId": { "type": "string" } }
      }
    },
    {
      "name": "verifier.reports.list.fetched",
      "trigger": "GET /verifier/reports completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "verifier.reports.error",
      "trigger": "Any of the reports endpoints returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
