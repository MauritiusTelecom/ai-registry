{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "admin.resources",
  "description": "Telemetry events emitted by the Admin portal /resources route. All events carry the standard envelope (actorId, sessionId, ts, traceId).",
  "events": [
    {
      "name": "admin.resources.viewed",
      "trigger": "AdminResources component mounts.",
      "payload": {
        "type": "object",
        "required": ["totalCount", "filters"],
        "properties": {
          "totalCount": { "type": "integer" },
          "filters": {
            "type": "object",
            "properties": {
              "q": { "type": "string" },
              "kind": { "type": "string" },
              "status": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "name": "admin.resources.filtered",
      "trigger": "Any of q, kind, status changes; debounce 250ms on q.",
      "payload": {
        "type": "object",
        "required": ["filters", "resultCount"],
        "properties": {
          "filters": {
            "type": "object",
            "properties": {
              "q": { "type": "string" },
              "kind": { "type": "string" },
              "status": { "type": "string" }
            }
          },
          "resultCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "admin.resources.row.clicked",
      "trigger": "User clicks a row in the resources DataTable; opens drawer.",
      "payload": {
        "type": "object",
        "required": ["resourceId", "kind", "status"],
        "properties": {
          "resourceId": { "type": "string" },
          "slug":       { "type": "string" },
          "kind":       { "type": "string" },
          "status":     { "type": "string" }
        }
      }
    },
    {
      "name": "admin.resources.drawer.opened",
      "trigger": "ResourceDrawer mounts (selectedRow → non-null)."
    },
    {
      "name": "admin.resources.drawer.closed",
      "trigger": "ResourceDrawer unmounts (selectedRow → null)."
    },
    {
      "name": "admin.resources.action.export_csv.clicked",
      "trigger": "User clicks 'Export CSV' header secondary button."
    },
    {
      "name": "admin.resources.action.new_resource.clicked",
      "trigger": "User clicks 'New resource' header primary button."
    },
    {
      "name": "admin.resources.drawer.action.reverify.clicked",
      "trigger": "User clicks 'Re-verify' in the drawer action row.",
      "payload": {
        "type": "object",
        "required": ["resourceId"],
        "properties": { "resourceId": { "type": "string" } }
      }
    },
    {
      "name": "admin.resources.drawer.action.edit.clicked",
      "trigger": "User clicks 'Edit' in the drawer action row.",
      "payload": {
        "type": "object",
        "required": ["resourceId"],
        "properties": { "resourceId": { "type": "string" } }
      }
    },
    {
      "name": "admin.resources.drawer.action.raise_flag.clicked",
      "trigger": "User clicks 'Raise flag' in the drawer action row.",
      "payload": {
        "type": "object",
        "required": ["resourceId"],
        "properties": { "resourceId": { "type": "string" } }
      }
    },
    {
      "name": "admin.resources.drawer.action.isolate.clicked",
      "trigger": "User clicks 'Isolate' in the drawer action row.",
      "payload": {
        "type": "object",
        "required": ["resourceId"],
        "properties": { "resourceId": { "type": "string" } }
      }
    },
    {
      "name": "admin.resources.list.fetched",
      "trigger": "GET /admin/resources completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "admin.resources.error",
      "trigger": "Any of the resources endpoints returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
