{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "admin.dashboard",
  "description": "Telemetry events emitted by the Admin portal dashboard route. All events carry the standard envelope (actorId, sessionId, ts, traceId) defined in airegistry-specs/shared/auth.md.",
  "events": [
    {
      "name": "admin.dashboard.viewed",
      "trigger": "AdminDashboard component mount after the admin portal shell finishes hydration.",
      "payload": {
        "type": "object",
        "required": ["route", "summary", "openFlagsCount", "recentActivityCount"],
        "properties": {
          "route": { "const": "/" },
          "summary": {
            "type": "object",
            "properties": {
              "resourcesTotal": { "type": "integer" },
              "providersTotal": { "type": "integer" },
              "pendingReviewsTotal": { "type": "integer" },
              "policyViolationsTotal": { "type": "integer" }
            }
          },
          "openFlagsCount": { "type": "integer", "minimum": 0, "maximum": 4 },
          "recentActivityCount": { "type": "integer", "minimum": 0, "maximum": 6 }
        }
      }
    },
    {
      "name": "admin.dashboard.action.open_status_page.clicked",
      "trigger": "User clicks the 'Open status page' secondary button in the PageHeader actions row."
    },
    {
      "name": "admin.dashboard.action.onboard_provider.clicked",
      "trigger": "User clicks the 'Onboard provider' primary button in the PageHeader actions row.",
      "side_effects": [
        "navigate(#/providers)"
      ]
    },
    {
      "name": "admin.dashboard.flags.see_all.clicked",
      "trigger": "User clicks the 'See all' link in the Open flags card header.",
      "side_effects": [
        "navigate(#/flags)"
      ]
    },
    {
      "name": "admin.dashboard.flag_row.viewed",
      "trigger": "Open flags card renders a flag row.",
      "payload": {
        "type": "object",
        "required": ["flagId", "severity", "kind"],
        "properties": {
          "flagId": { "type": "string" },
          "severity": { "enum": ["high", "med", "low"] },
          "kind": { "type": "string" }
        }
      }
    },
    {
      "name": "admin.dashboard.audit.open.clicked",
      "trigger": "User clicks the 'Open audit log' link in the Recent activity card header.",
      "side_effects": [
        "navigate(#/audit)"
      ]
    },
    {
      "name": "admin.dashboard.audit_row.viewed",
      "trigger": "Recent activity card renders an audit row.",
      "payload": {
        "type": "object",
        "required": ["auditId", "action", "result"],
        "properties": {
          "auditId": { "type": "string" },
          "action": { "type": "string" },
          "result": { "enum": ["ok", "fail"] }
        }
      }
    },
    {
      "name": "admin.dashboard.summary.fetched",
      "trigger": "GET /admin/summary completes (success or failure).",
      "payload": {
        "type": "object",
        "required": ["status", "ms"],
        "properties": {
          "status": { "type": "integer" },
          "ms": { "type": "integer", "minimum": 0 },
          "fromCache": { "type": "boolean" }
        }
      }
    },
    {
      "name": "admin.dashboard.series.fetched",
      "trigger": "GET /admin/submissions-series completes."
    },
    {
      "name": "admin.dashboard.flags.fetched",
      "trigger": "GET /admin/flags/open completes."
    },
    {
      "name": "admin.dashboard.audit.fetched",
      "trigger": "GET /admin/audit/recent completes."
    },
    {
      "name": "admin.dashboard.error",
      "trigger": "Any of the dashboard endpoints returns non-2xx and the UI renders the error empty-state.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status": { "type": "integer" },
          "problem": { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
