{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "admin.dashboard",
  "description": "Explicit UI contract for the Admin portal dashboard route. Production must render every named element with the listed text, classes, icon, and binding so visual regression vs. the prototype is mechanical.",

  "route": {
    "portal": "admin",
    "path": "/",
    "html_entry": "portals/admin.html",
    "default_path_when_hash_empty": "/"
  },

  "design_tokens": {
    "theme_attribute": "data-theme on documentElement (dark | light)",
    "theme_storage_key": "air-theme",
    "palette_storage_key": "air-pal",
    "palettes": [
      { "id": 0, "label": "Sovereign", "primary_rgb": "59,130,246", "secondary_rgb": "6,182,212", "tertiary_rgb": "168,85,247" },
      { "id": 1, "label": "Pacific",   "primary_rgb": "20,184,166", "secondary_rgb": "52,211,153", "tertiary_rgb": "14,165,233" },
      { "id": 2, "label": "Coral",     "primary_rgb": "236,72,153", "secondary_rgb": "244,114,182", "tertiary_rgb": "168,85,247" },
      { "id": 3, "label": "Solar",     "primary_rgb": "245,158,11", "secondary_rgb": "251,191,36",  "tertiary_rgb": "239,68,68" }
    ],
    "css_custom_properties_used": [
      "--primary", "--primary-rgb",
      "--secondary", "--secondary-rgb",
      "--tertiary", "--tertiary-rgb",
      "--p-text-2", "--p-text-3",
      "--p-border", "--p-border-soft", "--p-border-grad",
      "--p-card-bg", "--p-input", "--p-row-hover",
      "--p-pos", "--p-neg",
      "--font-mono"
    ],
    "transition_root": "background-color 240ms ease, color 240ms ease"
  },

  "shell": {
    "component": "PortalShell",
    "props": {
      "role": "admin",
      "portalLabel": "Admin",
      "portalIcon": "shield",
      "currentTitle": "Dashboard",
      "breadcrumb": ["Admin", "Dashboard"]
    },
    "sidebar": {
      "logo_text": "AI Registry",
      "logo_sub_label": "Admin",
      "logo_sub_icon": "shield",
      "items": [
        { "id": "home",         "label": "Dashboard",          "icon": "home",     "path": "/" },
        { "divider": true, "id": "div_registry", "label": "Registry" },
        { "id": "resources",    "label": "Resources",          "icon": "layers",   "path": "/resources" },
        { "id": "providers",    "label": "Providers",          "icon": "users",    "path": "/providers" },
        { "divider": true, "id": "div_gov", "label": "Governance" },
        { "id": "reviews",      "label": "Review queue",       "icon": "check",    "path": "/reviews",       "badge": "14" },
        { "id": "flags",        "label": "Flags & incidents",  "icon": "flag",     "path": "/flags",         "badge": "3" },
        { "id": "policies",     "label": "Policies",           "icon": "shield",   "path": "/policies" },
        { "divider": true, "id": "div_ops", "label": "Operations" },
        { "id": "users",        "label": "Users & roles",      "icon": "user",     "path": "/users" },
        { "id": "audit",        "label": "Audit log",          "icon": "audit",    "path": "/audit" },
        { "id": "integrations", "label": "Integrations",       "icon": "cpu",      "path": "/integrations" },
        { "id": "settings",     "label": "Settings",           "icon": "settings", "path": "/settings" }
      ],
      "footer": {
        "status_dot": "pulse",
        "status_title": "All systems nominal",
        "status_sub": "99.97% · 90d SLO"
      }
    }
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title": "Sovereign control plane",
      "subtitle": "Admin overview of the registry — providers, resources, reviews and policy enforcement at a glance.",
      "actions": [
        { "kind": "Btn", "variant": "secondary", "icon": "arrow-up-right", "label": "Open status page", "test_id": "admin.dashboard.action.open_status_page" },
        { "kind": "Btn", "variant": "primary",   "icon": "plus",            "label": "Onboard provider",  "test_id": "admin.dashboard.action.onboard_provider" }
      ]
    },

    "stat_grid": {
      "container_class": "p-grid p-grid-4",
      "container_style": { "marginBottom": 20 },
      "cards": [
        { "label": "Resources",          "value": 412, "delta": "+18", "deltaTone": "pos", "sub": "last 7 days", "icon": "layers", "test_id": "admin.dashboard.stat.resources" },
        { "label": "Providers",          "value": 64,  "delta": "+2",  "deltaTone": "pos", "sub": "onboarded",   "icon": "users",  "test_id": "admin.dashboard.stat.providers" },
        { "label": "Pending reviews",    "value": 14,  "delta": "+3",  "deltaTone": "neg", "sub": "queue",       "icon": "check",  "test_id": "admin.dashboard.stat.pendingReviews" },
        { "label": "Policy violations",  "value": 2,   "delta": "-4",  "deltaTone": "pos", "sub": "this week",   "icon": "shield", "test_id": "admin.dashboard.stat.policyViolations" }
      ]
    },

    "split_row": {
      "container_class": "p-grid p-grid-2",
      "container_style": { "marginBottom": 20, "gridTemplateColumns": "2fr 1fr" },
      "left_card": {
        "component": "p-card",
        "head": {
          "title": "Submissions over time",
          "sub": "last 60 days · provider, sovereign, external",
          "right": {
            "kind": "legend",
            "items": [
              { "label": "provider",  "swatch_token": "var(--primary)" },
              { "label": "sovereign", "swatch_token": "var(--secondary)" },
              { "label": "external",  "swatch_token": "var(--tertiary)" }
            ],
            "style": { "fontSize": 11, "color": "var(--p-text-3)", "gap": 14 }
          }
        },
        "body": {
          "component": "DashboardChart",
          "viewBox": "0 0 720 220",
          "padding": 24,
          "days": 60,
          "y_max": 22,
          "grid_lines": 5,
          "grid_stroke": "var(--p-border)",
          "grid_stroke_width": 0.8,
          "grid_dash": "2 4",
          "series_order": ["tertiary", "secondary", "primary"],
          "series_stroke_width": 1.6,
          "series_fill_opacity": 0.08
        }
      },
      "right_card": {
        "component": "p-card",
        "head": {
          "title": "Open flags",
          "right_link": { "label": "See all", "href": "#/flags", "class": "p-link", "test_id": "admin.dashboard.flags.see_all" }
        },
        "body": {
          "kind": "list",
          "filter": "status !== 'resolved'",
          "limit": 4,
          "row_template": {
            "title_field": "target",
            "title_class": "p-cell-strong",
            "title_style": { "fontSize": 13, "fontWeight": 500 },
            "meta_template": "${kind} · raised ${raised}",
            "meta_class": "p-cell-meta",
            "pill_class_map": { "high": "p-pill p-pill-isolated", "med": "p-pill p-pill-pending", "low": "p-pill p-pill-draft" },
            "pill_dot_class": "p-pill-dot",
            "row_border_bottom": "1px solid var(--p-border-soft)",
            "row_padding": "8px 0"
          }
        }
      }
    },

    "recent_activity_card": {
      "component": "p-card",
      "head": {
        "title": "Recent activity",
        "sub": "All actions are notarised in the audit ledger.",
        "right_link": { "label": "Open audit log", "href": "#/audit", "class": "p-link", "test_id": "admin.dashboard.audit.open" }
      },
      "body": {
        "component": "DataTable",
        "row_click_bound": false,
        "row_limit": 6,
        "columns": [
          { "key": "ts",     "label": "Time",   "width": 160, "cell_class": "p-mono-key" },
          { "key": "actor",  "label": "Actor",                 "cell_class": "p-cell-strong" },
          { "key": "action", "label": "Action",                "cell_class": "p-mono-val" },
          { "key": "target", "label": "Target",                "cell_class": "p-mono-val" },
          { "key": "result", "label": "Result", "width": 100,  "cell_renderer": "StatusPill", "cell_renderer_args": "ok ? 'verified' : 'failed'" }
        ]
      }
    }
  },

  "icons": {
    "renderer": "PIcon (portal-shell.jsx)",
    "default_size": 16,
    "default_stroke": 1.6,
    "names_used_on_this_page": [
      "home", "layers", "users", "shield", "flag", "check",
      "user", "audit", "cpu", "settings", "arrow-up-right", "plus"
    ]
  },

  "status_pill_states_used_on_this_page": [
    { "name": "verified", "tone": "pos" },
    { "name": "failed",   "tone": "neg" },
    { "name": "pending",  "tone": "warn",    "applied_via": "p-pill-pending" },
    { "name": "isolated", "tone": "neg",     "applied_via": "p-pill-isolated" },
    { "name": "draft",    "tone": "neutral", "applied_via": "p-pill-draft" }
  ],

  "interactions": [
    { "id": "open_status_page",  "trigger_test_id": "admin.dashboard.action.open_status_page", "effect": "open_external_url",     "url_default": "https://status.air.gov.mu" },
    { "id": "onboard_provider",  "trigger_test_id": "admin.dashboard.action.onboard_provider", "effect": "navigate",              "to": "/providers" },
    { "id": "flags_see_all",     "trigger_test_id": "admin.dashboard.flags.see_all",            "effect": "navigate",              "to": "/flags" },
    { "id": "audit_open",        "trigger_test_id": "admin.dashboard.audit.open",               "effect": "navigate",              "to": "/audit" }
  ],

  "empty_states": {
    "open_flags_empty": { "body_text": "No open flags." },
    "recent_activity_empty": { "body_row_text": "No recent activity. The audit ledger is sealed." }
  },

  "error_states": {
    "fetch_failed": {
      "card_body_replacement": {
        "title": "Couldn't load",
        "cta_label": "Try again",
        "telemetry_event": "admin.dashboard.error"
      }
    }
  },

  "non_negotiables": [
    "Card layout grid widths and gaps must match: p-grid-4 for stats; gridTemplateColumns '2fr 1fr' for the split row.",
    "Chart series order must remain tertiary → secondary → primary so the primary series paints on top.",
    "Recent activity DataTable must NOT bind onRowClick on this page.",
    "Flag list must be filtered by status !== 'resolved' BEFORE slicing to 4 rows.",
    "All copy strings in this contract are authoritative; do not paraphrase."
  ]
}
