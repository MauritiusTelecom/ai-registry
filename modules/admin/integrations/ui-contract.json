{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "admin.integrations",
  "description": "Explicit UI contract for the Admin portal /integrations route.",

  "route": {
    "portal": "admin",
    "path": "/integrations",
    "html_entry": "portals/admin.html"
  },

  "shell_overrides": {
    "currentTitle": "Integrations",
    "breadcrumb": ["Admin", "Operations", "Integrations"],
    "active_sidebar_item": "integrations"
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title": "Integrations",
      "subtitle": "Identity, observability, notifications and storage providers.",
      "actions": [
        { "kind": "Btn", "variant": "primary", "icon": "plus", "label": "Add integration", "test_id": "admin.integrations.action.add_integration" }
      ]
    },

    "card_grid": {
      "container_class": "p-grid p-grid-3",
      "card_template": {
        "component": "p-card",
        "head": {
          "left": {
            "kind": "stack",
            "lines": [
              { "binding": "name", "class": "p-card-title" },
              { "binding": "kind", "class": "p-card-sub" }
            ]
          },
          "right": {
            "kind": "renderer",
            "renderer": "StatusPill",
            "props": { "status": "row.status === 'connected' ? 'verified' : 'pending'" }
          }
        },
        "sync_row": {
          "container_class": "p-row",
          "container_style": { "justifyContent": "space-between", "marginTop": 4 },
          "left":  { "kind": "text", "class": "p-mono-key", "text": "last sync" },
          "right": { "kind": "text", "class": "p-mono-val", "binding": "lastSync" }
        },
        "divider_class": "p-divider",
        "actions_row": {
          "container_class": "p-row",
          "container_style": { "gap": 8 },
          "items": [
            { "kind": "Btn", "variant": "secondary", "size": "sm", "icon": "settings",       "label": "Configure", "test_id": "admin.integrations.card.configure" },
            { "kind": "Btn", "variant": "ghost",     "size": "sm", "icon": "arrow-up-right", "label": "Logs",      "test_id": "admin.integrations.card.logs" }
          ]
        }
      }
    }
  },

  "icons_used": ["plus", "settings", "arrow-up-right"],

  "status_pill_states_used": ["verified", "pending"],

  "interactions": [
    { "id": "add_integration", "trigger_test_id": "admin.integrations.action.add_integration", "effect": "open_kind_picker_then_setup_wizard" },
    { "id": "configure",       "trigger_test_id": "admin.integrations.card.configure",         "effect": "open_configure_drawer" },
    { "id": "logs",            "trigger_test_id": "admin.integrations.card.logs",              "effect": "navigate_to_logs_or_open_logs_drawer" }
  ],

  "empty_states": {
    "no_rows": {
      "single_full_width_card": true,
      "title": "No integrations connected.",
      "sub":   "Identity, notify, security, observability and storage providers will appear here once connected.",
      "cta_label": "Add integration"
    }
  },

  "non_negotiables": [
    "Page uses a card grid (p-grid p-grid-3), NOT a DataTable.",
    "Each card has exactly: head (title + sub on left, StatusPill on right) → sync row (last sync label + value) → divider → action row (Configure secondary sm + Logs ghost sm).",
    "Action buttons are size='sm' — smaller padding than default; do NOT eyeball-shrink.",
    "StatusPill mapping: connected → verified, anything else → pending.",
    "lastSync sentinel 'live' is rendered verbatim; production may add a slow-pulse dot prefix (recommended) but the literal text 'live' MUST appear.",
    "Secrets MUST NEVER appear in the list response or any card body — only `<set>` sentinels in the detail drawer."
  ]
}
