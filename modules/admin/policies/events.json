{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "admin.policies",
  "description": "Telemetry events emitted by the Admin portal /policies route. All events carry the standard envelope (actorId, sessionId, ts, traceId).",
  "events": [
    {
      "name": "admin.policies.viewed",
      "trigger": "AdminPolicies mounts.",
      "payload": {
        "type": "object",
        "required": ["totalCount", "enforcedCount"],
        "properties": {
          "totalCount":    { "type": "integer" },
          "enforcedCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "admin.policies.action.new_policy.clicked",
      "trigger": "User clicks 'New policy' header primary button."
    },
    {
      "name": "admin.policies.list.fetched",
      "trigger": "GET /admin/policies completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "admin.policies.policy.published",
      "trigger": "POST /admin/policies (201) or POST /admin/policies/{id}/versions (201).",
      "payload": {
        "type": "object",
        "required": ["policyId", "version"],
        "properties": {
          "policyId": { "type": "string" },
          "version":  { "type": "string" }
        }
      }
    },
    {
      "name": "admin.policies.policy.enforcement_changed",
      "trigger": "POST /admin/policies/{id}/enforce (200).",
      "payload": {
        "type": "object",
        "required": ["policyId", "enforced"],
        "properties": {
          "policyId": { "type": "string" },
          "enforced": { "type": "boolean" }
        }
      }
    },
    {
      "name": "admin.policies.error",
      "trigger": "Any of the policies endpoints returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
