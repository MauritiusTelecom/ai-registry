{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "admin.policies",
  "description": "Explicit UI contract for the Admin portal /policies route.",

  "route": {
    "portal": "admin",
    "path": "/policies",
    "html_entry": "portals/admin.html"
  },

  "shell_overrides": {
    "currentTitle": "Policies",
    "breadcrumb": ["Admin", "Governance", "Policies"],
    "active_sidebar_item": "policies"
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title": "Policies",
      "subtitle": "Policy-as-code definitions enforced across the registry.",
      "actions": [
        { "kind": "Btn", "variant": "primary", "icon": "plus", "label": "New policy", "test_id": "admin.policies.action.new_policy" }
      ]
    },

    "data_table": {
      "component": "DataTable",
      "row_click_bound": false,
      "columns": [
        {
          "key": "name", "label": "Policy",
          "cell": {
            "kind": "stack",
            "class": "p-cell-stack",
            "lines": [
              { "binding": "name", "class": "p-cell-strong" },
              { "binding": "id",   "class": "p-cell-meta" }
            ]
          }
        },
        { "key": "scope",    "label": "Scope",    "width": 130, "cell": { "kind": "tag",  "class": "p-tag",      "binding": "scope" } },
        { "key": "version",  "label": "Version",  "width": 100, "cell": { "kind": "text", "class": "p-mono-val", "binding": "version" } },
        { "key": "updated",  "label": "Updated",  "width": 130, "cell": { "kind": "text", "class": "p-mono-key", "binding": "updated" } },
        { "key": "enforced", "label": "Enforced", "width": 110,
          "cell": {
            "kind": "text",
            "class": "mono",
            "style": { "fontSize": 11, "letterSpacing": ".08em" },
            "value_map": { "true": "YES", "false": "NO" },
            "color_map": { "true": "#10b981", "false": "var(--p-text-3)" },
            "binding": "enforced"
          }
        }
      ]
    }
  },

  "icons_used": ["plus"],

  "interactions": [
    { "id": "new_policy", "trigger_test_id": "admin.policies.action.new_policy", "effect": "navigate_to_create_or_open_modal" }
  ],

  "empty_states": {
    "no_rows": { "body_text": "No policies defined.", "cta_label": "Create your first policy" }
  },

  "non_negotiables": [
    "Header has only ONE action button (primary 'New policy').",
    "No StatCards and no FilterBar on this page in v0.4.",
    "Enforced cell renders the literal text 'YES' or 'NO' (uppercase) — colour is paired but not the only signal.",
    "Enforced colour mapping: true=#10b981, false=var(--p-text-3).",
    "DataTable rows are non-interactive in v0.4 — do NOT bind onRowClick.",
    "List response MUST NOT include the policy body (Rego/CEL source); fetch via the version endpoint when needed."
  ]
}
