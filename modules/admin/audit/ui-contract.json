{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "admin.audit",
  "description": "Explicit UI contract for the Admin portal /audit route.",

  "route": {
    "portal": "admin",
    "path": "/audit",
    "html_entry": "portals/admin.html"
  },

  "shell_overrides": {
    "currentTitle": "Audit log",
    "breadcrumb": ["Admin", "Operations", "Audit"],
    "active_sidebar_item": "audit"
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title": "Audit log",
      "subtitle": "Append-only, content-addressed. Each block signed and notarised.",
      "actions": [
        { "kind": "Btn", "variant": "secondary", "icon": "arrow-up-right", "label": "Export",            "test_id": "admin.audit.action.export" },
        { "kind": "Btn", "variant": "secondary", "icon": "audit",           "label": "Verify integrity", "test_id": "admin.audit.action.verify" }
      ]
    },

    "data_table": {
      "component": "DataTable",
      "row_click_bound": false,
      "columns": [
        { "key": "id",     "label": "ID",        "width": 110, "cell": { "kind": "text", "class": "p-mono-val",   "binding": "id" } },
        { "key": "ts",     "label": "Time",      "width": 160, "cell": { "kind": "text", "class": "p-mono-key",   "binding": "ts" } },
        { "key": "actor",  "label": "Actor",                   "cell": { "kind": "text", "class": "p-cell-strong", "binding": "actor" } },
        { "key": "action", "label": "Action",                  "cell": { "kind": "text", "class": "p-mono-val",   "binding": "action" } },
        { "key": "target", "label": "Target",                  "cell": { "kind": "text", "class": "p-mono-val",   "binding": "target" } },
        { "key": "result", "label": "Result",    "width": 110,
          "cell": {
            "kind": "renderer",
            "renderer": "StatusPill",
            "props": { "status": "row.result === 'ok' ? 'verified' : 'failed'" }
          }
        },
        { "key": "sig",    "label": "Signature", "width": 100, "cell": { "kind": "text", "class": "p-mono-key", "binding": "sig" } }
      ]
    }
  },

  "icons_used": ["arrow-up-right", "audit"],

  "status_pill_states_used": ["verified", "failed"],

  "interactions": [
    { "id": "export", "trigger_test_id": "admin.audit.action.export", "effect": "open_format_dropdown_then_download" },
    { "id": "verify", "trigger_test_id": "admin.audit.action.verify", "effect": "post_verify_then_poll_with_toast" }
  ],

  "empty_states": {
    "no_rows": { "body_text": "No audit records in this range." }
  },

  "non_negotiables": [
    "Header has TWO secondary action buttons in this exact order: 'Export' → 'Verify integrity'. NO primary button.",
    "No StatCards and no FilterBar on this page in v0.4.",
    "Result column maps row.result enum to StatusPill: 'ok' → verified, 'fail' → failed.",
    "Signature cell uses Unicode horizontal ellipsis (U+2026) — NOT three dots.",
    "DataTable rows are non-interactive in v0.4 — do NOT bind onRowClick.",
    "The audit ledger is append-only — UI MUST NEVER offer edit / delete affordances under any role."
  ]
}
