{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "admin.audit",
  "description": "Telemetry events emitted by the Admin portal /audit route. Distinct from the audit ledger itself: these are UX telemetry events about how operators view the ledger.",
  "events": [
    {
      "name": "admin.audit.viewed",
      "trigger": "AdminAudit mounts.",
      "payload": {
        "type": "object",
        "required": ["totalCount"],
        "properties": {
          "totalCount": { "type": "integer" },
          "asOfBlock":  { "type": "string" }
        }
      }
    },
    {
      "name": "admin.audit.action.export.clicked",
      "trigger": "User clicks 'Export' header secondary button.",
      "payload": {
        "type": "object",
        "properties": {
          "format": { "enum": ["csv", "jsonl"] }
        }
      }
    },
    {
      "name": "admin.audit.action.verify.clicked",
      "trigger": "User clicks 'Verify integrity' header secondary button."
    },
    {
      "name": "admin.audit.verify.started",
      "trigger": "POST /admin/audit/verify accepts the job (202).",
      "payload": {
        "type": "object",
        "required": ["jobId", "since", "until"],
        "properties": {
          "jobId": { "type": "string" },
          "since": { "type": "string", "format": "date-time" },
          "until": { "type": "string", "format": "date-time" }
        }
      }
    },
    {
      "name": "admin.audit.verify.completed",
      "trigger": "Verification job state becomes ok | mismatch | error.",
      "payload": {
        "type": "object",
        "required": ["jobId", "state"],
        "properties": {
          "jobId":          { "type": "string" },
          "state":          { "enum": ["ok", "mismatch", "error"] },
          "scannedRecords": { "type": "integer" },
          "scannedThrough": { "type": "string" },
          "mismatchAt":     { "type": "string" }
        }
      }
    },
    {
      "name": "admin.audit.list.fetched",
      "trigger": "GET /admin/audit completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "admin.audit.error",
      "trigger": "Any of the audit endpoints returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
