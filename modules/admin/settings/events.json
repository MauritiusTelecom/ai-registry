{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "admin.settings",
  "description": "Telemetry events emitted by the Admin portal /settings route. All events carry the standard envelope (actorId, sessionId, ts, traceId).",
  "events": [
    {
      "name": "admin.settings.viewed",
      "trigger": "AdminSettings mounts."
    },
    {
      "name": "admin.settings.field.changed",
      "trigger": "Any field's value changes (debounced 250ms in production).",
      "payload": {
        "type": "object",
        "required": ["card", "field"],
        "properties": {
          "card":  { "enum": ["identity", "sovereignty", "audit", "branding"] },
          "field": { "type": "string" }
        }
      }
    },
    {
      "name": "admin.settings.identity.saved",
      "trigger": "PATCH /admin/settings/identity (200).",
      "payload": {
        "type": "object",
        "required": ["fields"],
        "properties": {
          "fields": {
            "type": "array",
            "items": { "enum": ["primaryIdp", "mfaEnforcement", "sessionLifetime"] }
          }
        }
      }
    },
    {
      "name": "admin.settings.sovereignty.saved",
      "trigger": "PATCH /admin/settings/sovereignty (200).",
      "payload": {
        "type": "object",
        "required": ["fields"],
        "properties": {
          "fields": {
            "type": "array",
            "items": { "enum": ["defaultTier", "egressPosture", "dpiaThreshold"] }
          }
        }
      }
    },
    {
      "name": "admin.settings.audit.saved",
      "trigger": "PATCH /admin/settings/audit (200).",
      "payload": {
        "type": "object",
        "required": ["fields"],
        "properties": {
          "fields": {
            "type": "array",
            "items": { "enum": ["retention", "notarisationCadence", "archiveBucket"] }
          }
        }
      }
    },
    {
      "name": "admin.settings.branding.saved",
      "trigger": "PATCH /admin/settings/branding (200).",
      "payload": {
        "type": "object",
        "required": ["fields"],
        "properties": {
          "fields": {
            "type": "array",
            "items": { "enum": ["publicName", "supportEmail", "statusPage"] }
          }
        }
      }
    },
    {
      "name": "admin.settings.idp.warning_shown",
      "trigger": "Operator changes identity.primaryIdp; SPA shows the all-sessions-will-end warning.",
      "payload": {
        "type": "object",
        "properties": {
          "from": { "type": "string" },
          "to":   { "type": "string" }
        }
      }
    },
    {
      "name": "admin.settings.fetched",
      "trigger": "GET /admin/settings completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms"],
        "properties": {
          "status": { "type": "integer" },
          "ms":     { "type": "integer", "minimum": 0 }
        }
      }
    },
    {
      "name": "admin.settings.error",
      "trigger": "Any settings endpoint returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
