{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "admin.flags",
  "description": "Telemetry events emitted by the Admin portal /flags route. All events carry the standard envelope (actorId, sessionId, ts, traceId).",
  "events": [
    {
      "name": "admin.flags.viewed",
      "trigger": "AdminFlags mounts.",
      "payload": {
        "type": "object",
        "required": ["totalCount", "openCount"],
        "properties": {
          "totalCount": { "type": "integer" },
          "openCount":  { "type": "integer" }
        }
      }
    },
    {
      "name": "admin.flags.action.raise_flag.clicked",
      "trigger": "User clicks 'Raise flag' header primary button."
    },
    {
      "name": "admin.flags.action.raise_flag.submitted",
      "trigger": "Raise-flag modal submits successfully (POST /admin/flags 201).",
      "payload": {
        "type": "object",
        "required": ["flagId", "target", "kind", "severity"],
        "properties": {
          "flagId":   { "type": "string" },
          "target":   { "type": "string" },
          "kind":     { "type": "string" },
          "severity": { "enum": ["high", "med", "low"] }
        }
      }
    },
    {
      "name": "admin.flags.list.fetched",
      "trigger": "GET /admin/flags completes.",
      "payload": {
        "type": "object",
        "required": ["status", "ms", "rowCount"],
        "properties": {
          "status":   { "type": "integer" },
          "ms":       { "type": "integer", "minimum": 0 },
          "rowCount": { "type": "integer" }
        }
      }
    },
    {
      "name": "admin.flags.flag.escalated",
      "trigger": "POST /admin/flags/{id}/escalate succeeds (production-only).",
      "payload": {
        "type": "object",
        "required": ["flagId"],
        "properties": {
          "flagId":   { "type": "string" },
          "reviewId": { "type": "string" }
        }
      }
    },
    {
      "name": "admin.flags.flag.resolved",
      "trigger": "POST /admin/flags/{id}/resolve succeeds (production-only).",
      "payload": {
        "type": "object",
        "required": ["flagId", "auditId"],
        "properties": {
          "flagId":  { "type": "string" },
          "auditId": { "type": "string" }
        }
      }
    },
    {
      "name": "admin.flags.flag.reopened",
      "trigger": "POST /admin/flags/{id}/reopen succeeds (production-only).",
      "payload": {
        "type": "object",
        "required": ["flagId"],
        "properties": { "flagId": { "type": "string" } }
      }
    },
    {
      "name": "admin.flags.error",
      "trigger": "Any of the flags endpoints returns non-2xx.",
      "payload": {
        "type": "object",
        "required": ["endpoint", "status"],
        "properties": {
          "endpoint": { "type": "string" },
          "status":   { "type": "integer" },
          "problem":  { "type": "string" }
        }
      }
    }
  ],
  "shell_events_inherited": [
    "shell.command_palette.opened",
    "shell.command_palette.executed",
    "shell.theme.toggled",
    "shell.palette.changed",
    "shell.notifications.opened",
    "shell.user_menu.opened",
    "shell.role.switched",
    "shell.signed_out"
  ]
}
