{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "module": "admin.flags",
  "description": "Explicit UI contract for the Admin portal /flags route.",

  "route": {
    "portal": "admin",
    "path": "/flags",
    "html_entry": "portals/admin.html"
  },

  "shell_overrides": {
    "currentTitle": "Flags & incidents",
    "breadcrumb": ["Admin", "Governance", "Flags"],
    "active_sidebar_item": "flags",
    "sidebar_badge": "3"
  },

  "page": {
    "header": {
      "component": "PageHeader",
      "title": "Flags & incidents",
      "subtitle": "Automated and manual flags raised against registry entries.",
      "actions": [
        { "kind": "Btn", "variant": "primary", "icon": "plus", "label": "Raise flag", "test_id": "admin.flags.action.raise_flag" }
      ]
    },

    "data_table": {
      "component": "DataTable",
      "row_click_bound": false,
      "columns": [
        { "key": "id",       "label": "Flag",     "width": 110, "cell": { "kind": "text", "class": "p-mono-val",   "binding": "id" } },
        { "key": "target",   "label": "Target",                "cell": { "kind": "text", "class": "p-cell-strong", "binding": "target" } },
        { "key": "kind",     "label": "Kind",                  "cell": { "kind": "tag",  "class": "p-tag",         "binding": "kind" } },
        { "key": "severity", "label": "Severity", "width": 110,
          "cell": {
            "kind": "pill",
            "pill_class_map": { "high": "p-pill p-pill-isolated", "med": "p-pill p-pill-pending", "low": "p-pill p-pill-draft" },
            "pill_dot_class": "p-pill-dot",
            "binding": "severity"
          }
        },
        { "key": "raisedBy", "label": "Raised by",              "cell": { "kind": "text", "style": { "color": "var(--p-text-2)" }, "binding": "raisedBy" } },
        { "key": "raised",   "label": "Raised",   "width": 110, "cell": { "kind": "text", "class": "p-mono-key", "binding": "raised" } },
        { "key": "status",   "label": "Status",   "width": 110,
          "cell": {
            "kind": "renderer",
            "renderer": "StatusPill",
            "props": { "status": "row.status === 'open' ? 'pending' : row.status === 'review' ? 'review' : 'verified'" }
          }
        }
      ]
    }
  },

  "icons_used": ["plus"],

  "status_pill_states_used": ["pending", "review", "verified"],

  "interactions": [
    { "id": "raise_flag", "trigger_test_id": "admin.flags.action.raise_flag", "effect": "open_create_flag_modal" }
  ],

  "empty_states": {
    "no_rows": { "body_text": "No flags raised. Quiet day." }
  },

  "non_negotiables": [
    "Header has only ONE action button (primary 'Raise flag').",
    "No StatCards and no FilterBar on this page in v0.4.",
    "Severity pill mapping: high → p-pill-isolated, med → p-pill-pending, low → p-pill-draft.",
    "Status column maps the persisted enum to a different StatusPill visual (open→pending, review→review, resolved→verified).",
    "DataTable rows are non-interactive in v0.4 — do NOT bind onRowClick.",
    "Sidebar badge value comes from openCount in the list endpoint, not from page row count."
  ]
}
